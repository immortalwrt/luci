msgid ""
msgstr "Content-Type: text/plain; charset=UTF-8\n"

msgid "Network Wizard"
msgstr "网络设置向导"

msgid "Netwiz NETWORK SETUP"
msgstr "Netwiz 网络设置向导"

msgid "Pure · Secure · Non-destructive Minimalist Config"
msgstr "纯粹 · 安全 · 无损的极简配置"

msgid "Secondary Router Mode"
msgstr "二级路由模式"

msgid "Upstream network dials up, this device acts as a secondary router."
msgstr "上级网络负责拨号，本设备作为二级路由使用。"

msgid "PPPoE Dial-up"
msgstr "PPPoE 拨号"

msgid "Dial up directly using account and password on this device."
msgstr "在本设备上直接使用宽带账号和密码进行拨号。"

msgid "LAN Settings"
msgstr "局域网设置"

msgid "Change device LAN IP, or switch to Bypass Router mode."
msgstr "修改设备的局域网 IP，或切换至旁路由模式。"

msgid "Reading underlying config..."
msgstr "正在读取底层配置..."

msgid "Back to Home"
msgstr "返回主页"

msgid "Configure WAN"
msgstr "配置外网 (WAN)"

msgid "Connection Type"
msgstr "连接方式"

msgid "DHCP (Auto)"
msgstr "自动获取 IP (DHCP)"

msgid "Static IP"
msgstr "静态 IP"

msgid "Gateway"
msgstr "网关"

msgid "e.g., 192.168.1.2"
msgstr "例如：192.168.1.2"

msgid "e.g., 192.168.1.1"
msgstr "例如：192.168.1.1"

msgid "PPPoE Credentials"
msgstr "PPPoE 拨号信息"

msgid "PPPoE Username"
msgstr "宽带账号"

msgid "Enter PPPoE username"
msgstr "请输入宽带账号"

msgid "PPPoE Password"
msgstr "宽带密码"

msgid "Enter PPPoE password"
msgstr "请输入宽带密码"

msgid "Configure LAN"
msgstr "配置局域网 (LAN)"

msgid "Enable Bypass Mode"
msgstr "启用旁路由模式"

msgid "<b style=\"font-size: 16px;\">Bypass Mode Enabled:</b><br>1. DHCP will be disabled. <b style=\"color: #059669;\">Devices must use static IPs or get IPs from upstream.</b><br>2. Gateway MUST be the upstream router IP.<br>3. If LAN IP changes, ensure your client is in the same subnet to avoid <b style=\"color: #059669;\">losing access</b>."
msgstr "<b style=\"font-size: 16px;\">旁路由模式已启用：</b><br>1. DHCP 服务将被禁用，<b style=\"color: #059669;\">下级设备需手动指定 IP 或由上级路由分配。</b><br>2. 网关【必须】填写为上级路由器的 IP。<br>3. 若修改了局域网 IP，请确保您的设备也处于同网段，以免<b style=\"color: #059669;\">失去连接</b>。"

msgid "<b style=\"font-size: 16px;\">Main Router Mode Enabled:</b><br>1. DHCP will be enabled. This device assigns IPs.<br>2. Gateway is usually left blank.<br>3. If LAN IP changes, ensure your client is in the same subnet to avoid <b style=\"color: #dc2626;\">losing access</b>."
msgstr "<b style=\"font-size: 16px;\">主路由模式已启用：</b><br>1. DHCP 服务已开启，本设备将向下级分配 IP。<br>2. 作为主路由时，网关通常留空即可。<br>3. 若修改了局域网 IP，请确保您的设备也处于同网段，以免<b style=\"color: #dc2626;\">失去连接</b>。"

msgid "Device LAN IP"
msgstr "设备局域网 IP"

msgid "LAN Gateway"
msgstr "局域网网关"

msgid "Blank for Main, required for Bypass"
msgstr "主路由留空，旁路由必填"

msgid "Back"
msgstr "上一步"

msgid "Next Step"
msgstr "下一步"

msgid "Back to Edit"
msgstr "返回修改"

msgid "Confirm Configuration"
msgstr "确认配置信息"

msgid "The following settings will be applied, please verify:"
msgstr "即将应用以下网络配置，请仔细核对："

msgid "Application Notes:"
msgstr "应用须知："

msgid "After confirmation, the network will restart and apply new settings."
msgstr "确认后，系统将重启网络服务以应用新配置。"

msgid "The system will auto-refresh or redirect in 15 seconds."
msgstr "大约 15 秒后，页面将自动刷新或跳转。"

msgid "Apply Settings"
msgstr "确认并应用"

msgid "Bypass Mode"
msgstr "旁路由模式"

msgid "Main Router (PPPoE)"
msgstr "主路由 (PPPoE 拨号)"

msgid "Secondary Router (DHCP)"
msgstr "二级路由 (自动获取)"

msgid "Secondary Router (Static IP)"
msgstr "二级路由 (静态 IP)"

msgid "LAN Mode"
msgstr "局域网模式"

msgid "Device IP:"
msgstr "设备 IP："

msgid "Upstream GW:"
msgstr "上级网关："

msgid "Public IP:"
msgstr "公网 IP："

msgid "Remote GW:"
msgstr "远端网关："

msgid "LAN IP:"
msgstr "局域网 IP："

msgid "Status:"
msgstr "状态："

msgid "Waiting for remote response"
msgstr "等待远端响应..."

msgid "WAN IP:"
msgstr "外网 IP："

msgid "Getting IP..."
msgstr "正在获取 IP..."

msgid "DHCP Service:"
msgstr "DHCP 服务："

msgid "Enabled"
msgstr "已开启"

msgid "Disabled"
msgstr "已禁用"

msgid "Dial Success"
msgstr "拨号成功"

msgid "Dialing / Disconnected"
msgstr "拨号中 / 未连接"

msgid "IP Acquired"
msgstr "已获取 IP"

msgid "Waiting for IP..."
msgstr "等待分配 IP..."

msgid "Interface Connected"
msgstr "接口已连接"

msgid "Cable Unplugged"
msgstr "网线未插入"

msgid "Getting..."
msgstr "获取中..."

msgid "Not acquired"
msgstr "未获取"

msgid "Not set"
msgstr "未设置"

msgid "System read error, anti-freeze triggered"
msgstr "系统读取错误，已触发防卡死机制"

msgid "Underlying crash intercepted, please force refresh"
msgstr "已拦截到底层崩溃，请强制刷新页面"

msgid "Incomplete info"
msgstr "信息不完整"

msgid "Device IP cannot be empty."
msgstr "设备 IP 不能为空。"

msgid "Static IP and Gateway cannot be empty."
msgstr "静态 IP 和网关不能为空。"

msgid "PPPoE username and password cannot be empty."
msgstr "宽带账号和密码不能为空。"

msgid "Format Error"
msgstr "格式错误"

msgid "The device IP is invalid, please check!"
msgstr "设备 IP 格式不正确，请检查！"

msgid "WAN IP is invalid, please check!"
msgstr "外网 IP 格式不正确，请检查！"

msgid "Gateway IP is invalid, please check!"
msgstr "网关 IP 格式不正确，请检查！"

msgid "Logic Error"
msgstr "逻辑错误"

msgid "Bypass mode requires an upstream gateway IP."
msgstr "旁路由模式下，网关为必填项。"

msgid "WAN Static IP MUST NOT be the same as the gateway!"
msgstr "WAN 静态 IP 绝对不能和网关一模一样！"

msgid "The Bypass Device IP MUST NOT be the same as the Gateway!"
msgstr "旁路由的设备 IP 绝对不能和上级网关一模一样！"

msgid "No Changes Needed"
msgstr "未发生更改"

msgid "Your settings match the current router config exactly."
msgstr "您的设置与底层配置完全一致，无需重复下发。"

msgid "Exit to Home"
msgstr "返回主页"

msgid "Conflict Blocked"
msgstr "配置冲突拦截"

msgid "The WAN IP cannot be the same as the current LAN IP ({ip})!"
msgstr "WAN 口 IP 不能与当前局域网 IP ({ip}) 相同！"

msgid "The WAN port cannot be in the same subnet as the LAN ({ip})!"
msgstr "WAN 口不能与局域网 ({ip}) 处于同一网段！"

msgid "This causes a routing loop."
msgstr "这会导致严重的路由环路。"

msgid "Subnet Error"
msgstr "网段错误"

msgid "The WAN Static IP must be in the same subnet as the Gateway!"
msgstr "WAN 静态 IP 必须与网关处于同一网段！"

msgid "e.g., if gateway is {gw}, the IP must be {ip}.x"
msgstr "例如：如果网关是 {gw}，则 IP 必须是 {ip}.x"

msgid "The Bypass Device IP must be in the same subnet as the Gateway!"
msgstr "旁路由的设备 IP 必须与上级网关处于同一网段！"

msgid "LAN IP cannot be the same as the existing WAN IP ({ip})!"
msgstr "局域网 IP 不能与当前外网 IP ({ip}) 相同！"

msgid "LAN cannot be in the same subnet as WAN ({ip})!"
msgstr "局域网不能与外网 ({ip}) 处于同一网段！"

msgid "Config Warning"
msgstr "高危操作警告"

msgid "You selected [Main Router Mode] but filled in the [Gateway].<br><br><b>For a standard main router, the gateway must be blank.</b> Entering a gateway may cause the device to fail at distributing network, leading to a total outage!<br><br>Are you sure you want to do this?"
msgstr "您选择了【主路由模式】，但填写了【网关】。<br><br><b>作为主路由，网关必须留空。</b>强行指定网关极易导致底层路由表错乱，全屋断网！<br><br>您确定要继续强行保存吗？"

msgid "Force Apply"
msgstr "确认强行保存"

msgid "System Exception"
msgstr "系统异常"

msgid "Cannot read underlying config for validation, please refresh."
msgstr "无法读取底层配置进行防呆校验，请刷新页面重试。"

msgid "Applying Config"
msgstr "正在下发配置"

msgid "Writing request, please wait..."
msgstr "正在向底层写入请求，请耐心等待..."

msgid "Config Applied"
msgstr "配置下发成功"

msgid "Since the IP has changed to {ip},"
msgstr "由于 IP 已更改为 {ip}，"

msgid "the system will attempt to redirect to the new address in 15 seconds."
msgstr "系统将在 15 秒后尝试重定向至新地址。"

msgid "Note: You will need to log in again."
msgstr "注意：您需要重新登录。"

msgid "Applying Configuration"
msgstr "正在应用配置"

msgid "Underlying network is resetting, please wait...<br><br><span style=\"font-size: 14px; color: #555;\">(If it does not automatically return in 15s, manually refresh)</span>"
msgstr "底层网络服务正在重启，请稍候...<br><br><span style=\"font-size: 14px; color: #555;\">(若 15 秒后未自动返回，请手动刷新网页)</span>"

msgid "❌ Write Failed"
msgstr "❌ 写入失败"

msgid "Underlying call exception, please try logging in again."
msgstr "底层调用异常，请尝试重新登录。"

msgid "Error code: {code}"
msgstr "错误代码：{code}"

msgid "Close"
msgstr "关闭"

msgid "Account"
msgstr "账号"

msgid "Password"
msgstr "密码"

msgid "Hidden"
msgstr "已隐藏"

msgid "IP & Gateway"
msgstr "IP 与网关"

msgid "Auto-assigned by upstream router"
msgstr "由上级路由自动分配"
