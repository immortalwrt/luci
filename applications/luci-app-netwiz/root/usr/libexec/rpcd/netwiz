case "$1" in
    list)
        echo '{ "set_network": { "mode": "string", "arg1": "string", "arg2": "string", "arg3": "string", "arg4": "string", "arg5": "string", "arg6": "string" }, "set_password": { "password": "string" }, "check_wifi": {}, "confirm": {}, "smart_backup": { "type": "string" }, "smart_restore_exec": { "filepath": "string" }, "check_backup": {}, "check_storage": {}, "check_restore_status": {}, "check_ip_conflict": { "ip": "192.168.1.254" }, "check_missing_pkgs": {}, "get_wizard_status": {}, "set_wizard_status": { "mode": "string" }, "check_internet": {}, "get_client_mac": {}, "get_adv_settings": {}, "set_adv_settings": { "mac": "string", "web": "string", "cron": "string", "hosts": "string" }, "get_repairable_configs": {}, "repair_config": { "plugin": "string" } }'
        exit 0
        ;;
    call)
        case "$2" in

            get_repairable_configs)
                arr=""
                # 扫描系统所有的设定档
                for f in /etc/config/*; do
                    if [ -f "$f" ]; then
                        name=$(basename "$f")
                        
                        # 过滤高危网络核心组件以及后缀异常的临时档案
                        if echo "$name" | grep -qE "network|wireless|dhcp|firewall|system|dropbear|rpcd|uhttpd|luci|fstab|mac80211|netwiz|.*\.apk-new|.*\.bak"; then
                            continue
                        fi
                        
                        [ -n "$arr" ] && arr="$arr,"
                        arr="$arr\"$name\""
                    fi
                done
                
                # 回传数组给前端
                echo "{\"configs\": [$arr]}"
                exit 0
                ;;

            repair_config)
                input=$(cat)
                plugin=$(echo "$input" | jsonfilter -e '@.plugin')
                
                # 确保档案存在
                if [ -n "$plugin" ] && [ -f "/etc/config/$plugin" ]; then
                    log "[REPAIR]" ">>> 正在启动急救包，修复 $plugin 的设定档..."
                    
                    # 强制停止服务防止档案被占用
                    [ -f "/etc/init.d/$plugin" ] && /etc/init.d/$plugin stop 2>/dev/null
                    
                    # 双引擎判断
                    if [ -f "/rom/etc/config/$plugin" ]; then
                        # 固件内置外挂提取纯净版覆盖
                        log "[REPAIR]" "检测为固件内置外挂，从ROM还原官方预设值..."
                        cp -f "/rom/etc/config/$plugin" "/etc/config/$plugin"
                    else
                        # 后装外挂删除配置后重装
                        log "[REPAIR]" "检测为后装外挂，正在清理损坏配置并尝试通过底层重建..."
                        
                        # 彻底删除坏掉的设定档
                        rm -f "/etc/config/$plugin"
                        
                        # 寻找安装包并释放新的设定档
                        if command -v apk >/dev/null 2>&1; then
                            # 针对Alpine系统执行修复
                            pkg_name=$(apk info -W "/etc/config/$plugin" 2>/dev/null | awk '{print $1}' | head -n1)
                            if [ -n "$pkg_name" ]; then
                                log "[REPAIR]" "已锁定所属套件 $pkg_name，正在执行 apk fix..."
                                apk fix "$pkg_name" >/dev/null 2>&1
                            fi
                        elif command -v opkg >/dev/null 2>&1; then
                            # 针对OpenWrt系统执行强制复写
                            pkg_name=$(opkg search "/etc/config/$plugin" 2>/dev/null | awk '{print $1}' | awk -F' - ' '{print $1}' | head -n1)
                            if [ -n "$pkg_name" ]; then
                                log "[REPAIR]" "已锁定所属套件 $pkg_name，正在执行强制复写重装..."
                                opkg install --force-reinstall --force-maintainer "$pkg_name" >/dev/null 2>&1
                            fi
                        fi
                        # 配置文件丢失时启动会自动生成新预设值
                    fi
                    
                    # 网络组件特殊重启加载新配置
                    if [ "$plugin" = "network" ] || [ "$plugin" = "dhcp" ] || [ "$plugin" = "wireless" ]; then
                        /etc/init.d/network restart >/dev/null 2>&1 &
                    elif [ "$plugin" = "firewall" ]; then
                        /etc/init.d/firewall restart >/dev/null 2>&1 &
                    else
                        # 一般外挂重启生效
                        [ -f "/etc/init.d/$plugin" ] && /etc/init.d/$plugin restart >/dev/null 2>&1 &
                    fi
                    
                    log "[REPAIR]" "✅ $plugin 恢复任务执行完毕！"
                    echo '{"result": 0}'
                else
                    log "[REPAIR]" "⚠️ 找不到 $plugin 的配置文件！无法执行修复。"
                    echo '{"result": 1, "error": "Not found"}'
                fi
                exit 0
                ;;

            set_password)
                input=$(cat)
                pwd=$(echo "$input" | jsonfilter -e '@.password')
                if [ -n "$pwd" ]; then
                    # 強制修改系統 root 密碼
                    (echo "$pwd"; echo "$pwd") | passwd root
                fi
                echo '{"result":0}'
                exit 0
                ;;
            check_wifi)
                has_wifi="false"
                # 1. 检测物理网卡底层接口
                if [ -n "$(ls -A /sys/class/net/wlan* 2>/dev/null)" ] || \
                   [ -n "$(ls -A /sys/class/net/ra* 2>/dev/null)" ] || \
                   [ -n "$(ls -A /sys/class/net/wl* 2>/dev/null)" ] || \
                   [ -n "$(ls -A /sys/class/net/ath* 2>/dev/null)" ]; then
                    has_wifi="true"
                # 2. 备用检测：iwinfo 射频状态
                elif iwinfo 2>/dev/null | grep -q -E "ESSID|Access Point|Mode"; then
                    has_wifi="true"
                fi
                
                # 只有真正检测到硬件，但配置文件丢失时，才生成配置
                if [ "$has_wifi" = "true" ] && [ ! -f /etc/config/wireless ]; then
                    wifi config > /etc/config/wireless 2>/dev/null
                fi

                # --- IPv6 与 LAN NAT 冲突检测 ---
                lan_zone_idx=$(uci show firewall 2>/dev/null | grep -E "\.name='?lan'?" | cut -d'.' -f2 | head -n 1)
                lan_nat_conflict="false"
                if [ -n "$lan_zone_idx" ]; then
                    lan_masq=$(uci -q get firewall.$lan_zone_idx.masq)
                    if [ "$lan_masq" = "1" ]; then
                        lan_nat_conflict="true"
                    fi
                fi
                # ------------------------------------------

                # --- 获取架构信息，供前端核对文件名防呆 ---
                pkg_type="ipk"
                command -v apk >/dev/null 2>&1 && pkg_type="apk"
                sys_arch=$(uname -m)

                # 输出，把冲突状态和架构信息一起传给前端
                echo "{\"has_wifi\":$has_wifi, \"lan_nat_conflict\":$lan_nat_conflict, \"pkg_type\":\"$pkg_type\", \"sys_arch\":\"$sys_arch\"}"
                exit 0
                ;;
            
            check_internet)
                if ping -c 1 -W 2 223.5.5.5 >/dev/null 2>&1 || ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then echo '{"status":"ok"}'; else echo '{"status":"fail"}'; fi
                exit 0
                ;;
            get_client_mac)
                # 找出当前正在连接路由器网页后台(80/443端口)的设备 IP，匹配 MAC
                client_ip=$(netstat -nt 2>/dev/null | awk '$4 ~ /:(80|443)$/ && $6 == "ESTABLISHED" {split($5, a, ":"); print a[1]}' | head -n 1)
                
                if [ -n "$client_ip" ]; then
                    mac=$(cat /proc/net/arp 2>/dev/null | awk -v ip="$client_ip" '$1 == ip {print $4}')
                fi
                
                # 兜底：降级抓取第一个活动的有效设备
                if [ -z "$mac" ] || [ "$mac" = "00:00:00:00:00:00" ]; then
                    mac=$(cat /proc/net/arp 2>/dev/null | grep -E "0x2" | grep -iv "00:00:00:00:00:00" | head -n 1 | awk '{print $4}')
                fi
                
                echo "{\"mac\":\"$mac\"}"
                exit 0
                ;;
            get_adv_settings)
                mac=$(uci -q get network.wan.macaddr)
                
                web="0"
                _src=$(uci -q get firewall.netwiz_web.src_dport 2>/dev/null)
                _dest=$(uci -q get firewall.netwiz_web.dest_port 2>/dev/null)
                
                if [ -n "$_src" ]; then
                    web="$_src"
                elif [ -n "$_dest" ]; then
                    if [ "$_dest" = "80 443" ]; then
                        web="1"
                    else
                        web="$_dest"
                    fi
                fi
                
                cron="off"
                if grep -q "netwiz_reboot" /etc/crontabs/root 2>/dev/null; then
                    cron=$(grep "netwiz_reboot" /etc/crontabs/root | head -n 1 | awk '{print $1" "$2" "$3" "$4" "$5}')
                fi
                
                hosts_json="[]"
                if [ -s /etc/netwiz/hosts.json ]; then
                    _tmp=$(cat /etc/netwiz/hosts.json 2>/dev/null)
                    [ -n "$_tmp" ] && hosts_json="$_tmp"
                fi
                
                # 从UCI配置文件读取曾经保存过的自定义端口
                last_port=$(uci -q get netwiz.main.web_port 2>/dev/null)
                [ -z "$last_port" ] && last_port="80"
                
                # --- 提取全局活跃公网 IPv6 地址 (过滤掉局域网 fd 开头的地址) ---
                wan6_ip=$(ip -o -6 addr list scope global 2>/dev/null | grep -v "deprecated" | grep -v " fd" | awk '{print $4}' | cut -d'/' -f1 | head -n 1)
                
                # 输出 JSON 时加上 last_port 和 wan6_ip
                echo "{\"mac\":\"$mac\", \"web\":\"$web\", \"cron\":\"$cron\", \"hosts\":$hosts_json, \"last_port\":\"$last_port\", \"wan6_ip\":\"$wan6_ip\"}"
                exit 0
                ;;
            set_adv_settings)
                input=$(cat)
                mac=$(echo "$input" | jsonfilter -e '@.mac')
                web=$(echo "$input" | jsonfilter -e '@.web')
                cron=$(echo "$input" | jsonfilter -e '@.cron')

                # --- 接收前端传来的 Hosts JSON 字符串 ---
                hosts_str=$(echo "$input" | jsonfilter -e '@.hosts')
                if echo "$input" | grep -q '"hosts"'; then
                    mkdir -p /etc/netwiz
                    echo "$hosts_str" > /etc/netwiz/hosts.json
                    
                    # 写入系统核心 /etc/hosts 
                    # 采用重定向写入，极其安全，不破坏 OpenWrt 底层系统软连接
                    cp /etc/hosts /tmp/hosts.bak 2>/dev/null
                    sed '/# === NETWIZ HOSTS BEGIN ===/,/# === NETWIZ HOSTS END ===/d' /tmp/hosts.bak > /etc/hosts
                    rm -f /tmp/hosts.bak
                    
                    # 写入新数据
                    if [ -n "$hosts_str" ] && [ "$hosts_str" != "[]" ]; then
                        echo "# === NETWIZ HOSTS BEGIN ===" >> /etc/hosts
                        echo "$hosts_str" | sed 's/},{/\n/g' | grep '"en":true' | sed 's/.*"ip":"\([^"]*\)".*"dom":"\([^"]*\)".*/\1 \2/' >> /etc/hosts
                        echo "# === NETWIZ HOSTS END ===" >> /etc/hosts
                    fi
                    
                    # 清理上一版可能残留的旧配置
                    if uci -q get dhcp.@dnsmasq[0].addnhosts | grep -q '/etc/dnsmasq.hosts.custom'; then
                        uci del_list dhcp.@dnsmasq[0].addnhosts='/etc/dnsmasq.hosts.custom'
                        uci commit dhcp
                    fi
                    
                    # 重启底层 dnsmasq，所有插件都会瞬间读取到 /etc/hosts 的新规则
                    /etc/init.d/dnsmasq restart &
                fi
                
                if [ -n "$mac" ]; then
                    if [ "$mac" = "none" ]; then uci delete network.wan.macaddr 2>/dev/null
                    else uci set network.wan.macaddr="$mac"; fi
                    uci commit network
                    /etc/init.d/network restart &
                fi

                # ========== 1. 外网访问配置逻辑 (包含 Procd 保活) ==========
                if [ -n "$web" ]; then
                    
                # --- 后端核心安全校验 (防绕过与防注入) ---
                if [ "$web" != "0" ] && [ "$web" != "1" ] && [ "$web" != "80" ] && [ "$web" != "443" ]; then
                    if ! expr "$web" + 0 >/dev/null 2>&1; then echo '{"status":"error", "msg":"Security Block: Invalid port format"}'; exit 0; fi
                    if [ "$web" -lt 1 ] || [ "$web" -gt 65535 ]; then echo '{"status":"error", "msg":"Security Block: Port out of range"}'; exit 0; fi
                    case "$web" in 21|22|23|53|67|68|445) echo '{"status":"error", "msg":"Security Block: Danger port is not allowed"}'; exit 0; ;; esac
                    
                    # 动态检测端口是否已被占用
                    if netstat -tuln 2>/dev/null | awk '{print $4}' | grep -E -q ":$web$"; then
                        is_uhttpd=$(netstat -tulpn 2>/dev/null | grep -E ":$web " | grep "uhttpd")
                        if [ -z "$is_uhttpd" ]; then
                            # exit 0 送达前端
                            echo '{"status":"error", "msg":"Port Conflict: Port '$web' is already in use by another application!"}'
                            exit 0
                        fi
                    fi
                fi
                # ----------------------------------------

                    # --- Web 服务端口联动 ---
                    # 彻底清空并重建 uhttpd 的 HTTP 监听列表，完美解决 option/list 冲突引发的静默失败
                    uci -q delete uhttpd.main.listen_http
                    uci add_list uhttpd.main.listen_http="0.0.0.0:80"
                    uci add_list uhttpd.main.listen_http="[::]:80"
                    
                    # 如果开启了外网访问且自定义了非标端口，则安全追加监听
                    if [ "$web" != "0" ] && [ "$web" != "1" ] && [ "$web" != "80" ] && [ "$web" != "443" ]; then
                        uci add_list uhttpd.main.listen_http="0.0.0.0:$web"
                        uci add_list uhttpd.main.listen_http="[::]:$web"
                    fi
                    uci commit uhttpd
                    # ----------------------------------------

                    uci -q delete firewall.netwiz_web
                    
                    # 记忆用户输入的非标端口统一保存到底层UCI配置文件
                    if [ "$web" != "0" ] && [ "$web" != "1" ] && [ "$web" != "80" ] && [ "$web" != "443" ]; then
                        [ ! -f /etc/config/netwiz ] && touch /etc/config/netwiz
                        uci -q get netwiz.main >/dev/null 2>&1 || uci set netwiz.main=main
                        uci set netwiz.main.web_port="$web"
                        uci commit netwiz
                    fi
                    
                    if [ "$web" != "0" ]; then
                        if [ "$web" = "1" ] || [ "$web" = "80" ] || [ "$web" = "443" ]; then
                            uci set firewall.netwiz_web=rule
                            uci set firewall.netwiz_web.name='Netwiz_Web_Access'
                            uci set firewall.netwiz_web.src='wan'
                            if [ "$web" = "1" ]; then
                                uci set firewall.netwiz_web.dest_port='80 443'
                            else
                                uci set firewall.netwiz_web.dest_port="$web"
                            fi
                            uci set firewall.netwiz_web.target='ACCEPT'
                            uci set firewall.netwiz_web.proto='tcp'
                        else
                            # --- 兼容 IPv6 的入站规则 (rule)，彻底废弃端口转发 (redirect) ---
                            uci set firewall.netwiz_web=rule
                            uci set firewall.netwiz_web.name='Netwiz_Web_Custom'
                            uci set firewall.netwiz_web.src='wan'
                            uci set firewall.netwiz_web.dest_port="$web"
                            uci set firewall.netwiz_web.target='ACCEPT'
                            uci set firewall.netwiz_web.proto='tcp'
                        fi

                        # 双保险：动态生成 OpenWrt 原生 procd 守护服务
                        cat << 'EOF' > /etc/init.d/netwiz-keepalive
#!/bin/sh /etc/rc.common
START=99
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /bin/sh -c "while true; do ping -6 -c 1 -W 1 2400:3200::1 >/dev/null 2>&1; sleep 20; done"
    procd_set_param respawn
    procd_close_instance
}
EOF
                        chmod +x /etc/init.d/netwiz-keepalive
                        /etc/init.d/netwiz-keepalive enable
                        /etc/init.d/netwiz-keepalive start

                    else
                        # 关闭外网访问时，停止并彻底销毁保活守护进程
                        if [ -f /etc/init.d/netwiz-keepalive ]; then
                            /etc/init.d/netwiz-keepalive stop >/dev/null 2>&1
                            /etc/init.d/netwiz-keepalive disable >/dev/null 2>&1
                            rm -f /etc/init.d/netwiz-keepalive
                        fi
                    fi
                    
                    uci commit firewall
                
                    # 背景执行防火墙重启与高级应用唤醒防止代理规则被冲刷
                    (
                        # 优先重启 uhttpd 让新端口立刻生效
                        /etc/init.d/uhttpd restart >/dev/null 2>&1
                        /etc/init.d/firewall restart >/dev/null 2>&1
                        # 等待防火墙完全启动后再次唤醒依赖网络的高级应用
                        sleep 8
                        restart_depend_apps >/dev/null 2>&1
                    ) &
                fi
                # ========== 2. 定时重启逻辑 (保留您原本的，完全不用改) ==========
                if [ -n "$cron" ]; then
                    touch /etc/crontabs/root
                    grep -v "netwiz_reboot" /etc/crontabs/root > /tmp/cron.tmp 2>/dev/null || true
                    if [ "$cron" != "off" ]; then echo "$cron sleep 70 && touch /etc/banner && reboot #netwiz_reboot" >> /tmp/cron.tmp; fi
                    mv /tmp/cron.tmp /etc/crontabs/root
                    /etc/init.d/cron restart 2>/dev/null
                fi
                echo '{"result":0}'
                exit 0
                ;;

            check_missing_pkgs)
                missing_pkgs=""
                provided_pkgs=""
                official_pkgs=""
                
                # 1. 取 /etc/netwiz/custom_pkgs/ 里面的文件
                for file in /etc/netwiz/custom_pkgs/*.[ia]pk; do
                    if [ -f "$file" ]; then
                        filename=$(basename "$file")
                        # 保险箱有netwiz，直接跳过，显示在「已备妥」清单
                        if echo "$filename" | grep -qi "netwiz"; then
                            continue
                        fi
                        provided_pkgs="$provided_pkgs $filename"
                    fi
                done

                # 2. 比对函数：是否备妥了该插件的安装包，兼容任意前缀、版本号后缀
                check_pkg_missing() {
                    local p=$1
                    if ls /etc/netwiz/custom_pkgs/*${p}*.[ia]pk >/dev/null 2>&1; then
                        : # 找到了包含该包名的物理文件，不做处理
                    else
                        missing_pkgs="$missing_pkgs $p"
                    fi
                }
                
                # 3. 扫描系统中已安裝与同步源
                if [ ! -f "/tmp/nw_pkg_updated_ok" ]; then
                    # 正在更新，直接抛错，掐断前端的重试请求，不堵塞网络
                    if [ -f "/tmp/nw_pkg_updating" ]; then
                        exit 1
                    fi
                    touch "/tmp/nw_pkg_updating"

                    if ping -c 1 -W 2 223.5.5.5 >/dev/null 2>&1 || ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then
                        log "[BACKUP]" "检测到网络畅通，正在同步软件源..."
                        
                        current_year=$(date +%Y)
                        if [ "$current_year" -lt 2024 ]; then
                            ntpd -n -q -p ntp.aliyun.com >/dev/null 2>&1 || ntpd -n -q -p time.apple.com >/dev/null 2>&1
                        fi
                        
                        if command -v opkg >/dev/null 2>&1; then
                            opkg update >/dev/null 2>&1
                        elif command -v apk >/dev/null 2>&1; then
                            apk update >/dev/null 2>&1
                        fi
                        
                        touch "/tmp/nw_pkg_updated_ok"
                        log "[BACKUP]" "软件源同步完毕！"
                    fi
                    rm -f "/tmp/nw_pkg_updating"
                fi

                # 4. 统一获取已安装列表与精准确比对
                installed=""
                # 优先使用 opkg！官方的无缝包装器
                if command -v opkg >/dev/null 2>&1; then
                    installed=$(opkg list-installed 2>/dev/null | awk '{print $1}' | grep -E "^luci-(app|theme)-")
                    
                    # 调用包装器生成官方包列表
                    avail_pkgs=$(opkg list 2>/dev/null | awk '{print $1}')
                    
                    for pkg in $installed; do
                        # opkg扫描时遇到netwiz相关文件直接跳过，不列入比对名单
                        if echo "$pkg" | grep -qi "netwiz"; then
                            continue
                        fi
                        
                        if echo "$avail_pkgs" | grep -qx "$pkg"; then
                            official_pkgs="$official_pkgs $pkg"
                        else
                            check_pkg_missing "$pkg"
                        fi
                    done
                    
                elif command -v apk >/dev/null 2>&1; then
                    # 仅在极限精简的纯血 apk 固件上才会走到这里
                    installed=$(apk info 2>/dev/null | grep -E "^luci-(app|theme)-")
                    if [ -z "$installed" ]; then
                        installed=$(apk list -I 2>/dev/null | awk '{print $1}' | grep -E "^luci-(app|theme)-")
                    fi
                    
                    for pkg in $installed; do
                        # apk扫描时遇到netwiz相关文件直接跳过，不列入比对名单
                        if echo "$pkg" | grep -qi "netwiz"; then
                            continue
                        fi
                        
                        # 精确查询，逐个查验
                        if [ -n "$(apk search -q -e "$pkg" 2>/dev/null)" ]; then
                            official_pkgs="$official_pkgs $pkg"
                        else
                            check_pkg_missing "$pkg"
                        fi
                    done
                fi
                
                # 4. JSON 阵列格式
                m_arr=""
                if [ -n "$missing_pkgs" ]; then m_arr='"'"$(echo "$missing_pkgs" | awk '{$1=$1;print}' | sed 's/ /","/g')"'"'; fi
                
                p_arr=""
                if [ -n "$provided_pkgs" ]; then p_arr='"'"$(echo "$provided_pkgs" | awk '{$1=$1;print}' | sed 's/ /","/g')"'"'; fi
                
                o_arr=""
                if [ -n "$official_pkgs" ]; then o_arr='"'"$(echo "$official_pkgs" | awk '{$1=$1;print}' | sed 's/ /","/g')"'"'; fi
                
                # 回传：缺失插件、文件插件、官方插件
                pkg_type="ipk"
                command -v apk >/dev/null 2>&1 && pkg_type="apk"
                sys_arch=$(uname -m)
                
                echo "{ \"missing\": [$m_arr], \"provided\": [$p_arr], \"official\": [$o_arr], \"pkg_type\": \"$pkg_type\", \"sys_arch\": \"$sys_arch\" }"
                ;;
                
            confirm)
                # 收到前端存活信号，连通性确认成功
                # 一键清理所有看门狗标记与健康备份档案
                if [ -f /tmp/netwiz_rollback_time ] || [ -f /etc/netwiz_pending_recovery ]; then
                    
                    # 拆除 LAN 120 秒看门狗与异常断电备份
                    rm -f /tmp/netwiz_rollback_time \
                          /tmp/netwiz_target_ip \
                          /etc/config/network.netwiz_bak \
                          /etc/config/dhcp.netwiz_bak \
                          /etc/config/network.netwiz_wan_bak
                          
                    # 拆除跨重启物理看门狗 (/etc)
                    rm -f /etc/netwiz_pending_recovery
                    rm -rf /etc/netwiz/failsafe
                    
                    log "前端已重新连接：已彻底拆除所有防失联回滚装置！"
                fi
                echo '{"status": "confirmed", "result": 0}'
                exit 0
                ;;
                
            check_ip_conflict)
                read input
                # 前端传來的 IP
                req_ip=$(echo "$input" | jsonfilter -e '@.ip')
                
                if ping -c 1 -W 1 "$req_ip" >/dev/null 2>&1; then
                    # Ping 通了，-> 冲突
                    echo '{ "status": "conflict" }'
                else
                    # Ping 不通，-> 安全
                    echo '{ "status": "safe" }'
                fi
                ;;

            # 获取向导状态与智能探针
                get_wizard_status)
                    configured=$(uci -q get netwiz.global.configured)
                    [ -z "$configured" ] && configured=0
                    
                    wizard_enable=$(uci -q get netwiz.main.wizard_enable)
                    [ -z "$wizard_enable" ] && wizard_enable=1

                    is_pppoe=0
                    wan_proto=$(uci -q get network.wan.proto)
                    wan_user=$(uci -q get network.wan.username)
                    if [ "$wan_proto" = "pppoe" ] && [ -n "$wan_user" ]; then
                        is_pppoe=1
                    fi

                    echo "{\"configured\": $configured, \"wizard_enable\": $wizard_enable, \"is_pppoe\": $is_pppoe}"
                    exit 0
                    ;;

                # 状态锁控
                set_wizard_status)
                    input=$(cat)
                    mode=$(echo "$input" | jsonfilter -e '@.mode')
                    
                    # 防呆
                    # 检查并创建节点，防止因为配置文件缺失导致的 uci set 静默失效
                    [ ! -f /etc/config/netwiz ] && touch /etc/config/netwiz
                    uci -q get netwiz.global >/dev/null 2>&1 || uci set netwiz.global=global
                    uci -q get netwiz.main >/dev/null 2>&1 || uci set netwiz.main=main

                    if [ "$mode" = "skip" ]; then
                        # 普通跳过
                        uci set netwiz.global.configured='1'
                    elif [ "$mode" = "restore" ]; then
                        # 手动恢复弹窗
                        uci set netwiz.global.configured='1'
                        uci set netwiz.main.wizard_enable='1'
                    elif [ "$mode" = "done" ]; then
                        # 彻底完成/不再提示
                        uci set netwiz.global.configured='1'
                        uci set netwiz.main.wizard_enable='0'
                    fi
                    
                    uci commit netwiz
                    sync  # 刷入物理闪存，防止丢失
                    
                    echo '{"result": 0}'
                    exit 0
                    ;;

            set_network)
                    set +e
                    
                    # 应用网络配置，死锁向导
                    [ ! -f /etc/config/netwiz ] && touch /etc/config/netwiz
                    uci -q get netwiz.global >/dev/null 2>&1 || uci set netwiz.global=global
                    uci -q get netwiz.main >/dev/null 2>&1 || uci set netwiz.main=main
                    
                    uci set netwiz.global.configured='1'
                    uci set netwiz.main.wizard_enable='0'
                    uci commit netwiz
                    sync  # 将RAM缓存瞬间刷入物理闪存，防止重启网络时丢失
                    
                    log "接收到前端下发的新配置，删除所有历史备份记录"

                rm -f /etc/config/network.netwiz_wan_bak /etc/config/network.netwiz_bak /etc/config/dhcp.netwiz_bak
                # ====================================================================

                input=$(cat)
                mode=$(echo "$input" | jsonfilter -e '@.mode')
                arg1=$(echo "$input" | jsonfilter -e '@.arg1')
                arg2=$(echo "$input" | jsonfilter -e '@.arg2')
                arg3=$(echo "$input" | jsonfilter -e '@.arg3')
                arg4=$(echo "$input" | jsonfilter -e '@.arg4')
                arg5=$(echo "$input" | jsonfilter -e '@.arg5')
                arg6=$(echo "$input" | jsonfilter -e '@.arg6')

                validate_strict_ip() {
                    if [ -n "$1" ] && ! echo "$1" | awk -F. 'NF==4 && $1>=0 && $1<=255 && $2>=0 && $2<=255 && $3>=0 && $3<=255 && $4>=0 && $4<=255 {print "ok"}' | grep -q "ok"; then
                        log "安全拦截 IP格式非法"
                        echo '{"result":1,"error":"Invalid format"}'
                        exit 1
                    fi
                }

                if [ "$mode" = "wan_static" ] || [ "$mode" = "lan" ]; then
                    validate_strict_ip "$arg1"
                    validate_strict_ip "$arg2"
                    validate_strict_ip "$arg3"
                fi

                cleanup_lan_for_wan_modes() {
                    uci delete network.lan.gateway 2>/dev/null || true
                    uci delete network.lan.dns 2>/dev/null || true
                    uci set dhcp.lan.ignore='0'
                }

                # --- 协议净化 ---
                cleanup_wan_for_proto() {
                    local target="$1"
                    
                    # 1. 切换后，统一刪除容易 netifd 死锁的 DHCP 干扰
                    uci delete network.wan.reqopts 2>/dev/null || true
                    uci delete network.wan.clientid 2>/dev/null || true
                    uci delete network.wan.vendorid 2>/dev/null || true
                    
                    # 2. 根据目标协议，删除「不兼容」的参数，保留dns、metric等共享高级设定
                    if [ "$target" = "pppoe" ]; then
                        uci delete network.wan.ipaddr 2>/dev/null || true
                        uci delete network.wan.netmask 2>/dev/null || true
                        uci delete network.wan.gateway 2>/dev/null || true
                    elif [ "$target" = "dhcp" ]; then
                        uci delete network.wan.ipaddr 2>/dev/null || true
                        uci delete network.wan.netmask 2>/dev/null || true
                        uci delete network.wan.gateway 2>/dev/null || true
                        uci delete network.wan.username 2>/dev/null || true
                        uci delete network.wan.password 2>/dev/null || true
                        uci delete network.wan.ipv6 2>/dev/null || true
                        uci delete network.wan.norelease 2>/dev/null || true
                        uci delete network.wan.multipath 2>/dev/null || true
                    elif [ "$target" = "static" ]; then
                        uci delete network.wan.username 2>/dev/null || true
                        uci delete network.wan.password 2>/dev/null || true
                        uci delete network.wan.ipv6 2>/dev/null || true
                        uci delete network.wan.norelease 2>/dev/null || true
                        uci delete network.wan.multipath 2>/dev/null || true
                    fi
                }
                # -------------------------------------------------------------

                CURRENT_LAN_IP=$(uci -q get network.lan.ipaddr | cut -d/ -f1)

                # 各模式网络写入
                
                # ====== 首次开机向导模式 (Wizard) ======
                # 一次性接收并处理上网方式与 Wi-Fi 设定，最后统一重启网络
                if [ "$mode" = "wizard" ]; then
                    log ">>> [向导模式] 开始执行双通道配置任务..."
                    
                    # 1. 提取向导中的路由/WAN参数
                    wiz_wan_type=$(echo "$arg1" | jsonfilter -e '@.wan_type' || echo "dhcp")
                    
                    cleanup_lan_for_wan_modes;
                    if [ "$wiz_wan_type" = "dhcp" ]; then
                        log "向导: 写入 DHCP 动态获取配置"
                        cleanup_wan_for_proto "dhcp"
                        uci set network.wan.proto='dhcp'
                    elif [ "$wiz_wan_type" = "static" ]; then
                        log "向导: 写入静态 IP 配置"
                        cleanup_wan_for_proto "static"
                        wiz_ip=$(echo "$arg1" | jsonfilter -e '@.ip')
                        wiz_gw=$(echo "$arg1" | jsonfilter -e '@.gw')
                        wiz_mask=$(echo "$arg1" | jsonfilter -e '@.mask')
                        
                        # 静默格式检查 (非法直接退回 DHCP 兜底，防止挂掉)
                        if echo "$wiz_ip" | awk -F. 'NF==4 {print "ok"}' | grep -q "ok" && \
                           echo "$wiz_gw" | awk -F. 'NF==4 {print "ok"}' | grep -q "ok"; then
                            uci set network.wan.proto='static'
                            uci set network.wan.ipaddr="$wiz_ip"
                            uci set network.wan.gateway="$wiz_gw"
                            uci set network.wan.netmask="$wiz_mask"
                        else
                            log "向导警告: 静态IP格式非法，安全回退至 DHCP"
                            cleanup_wan_for_proto "dhcp"
                            uci set network.wan.proto='dhcp'
                        fi
                    elif [ "$wiz_wan_type" = "pppoe" ]; then
                        log "向导: 写入 PPPoE 拨号配置"
                        wiz_user=$(echo "$arg1" | jsonfilter -e '@.user')
                        wiz_pass=$(echo "$arg1" | jsonfilter -e '@.pass')
                        cleanup_wan_for_proto "pppoe"
                        uci set network.wan.proto='pppoe'
                        [ -n "$wiz_user" ] && uci set network.wan.username="$wiz_user"
                        [ -n "$wiz_pass" ] && uci set network.wan.password="$wiz_pass"
                        
                        uci set network.wan.ipv6='auto'
                        uci set network.wan.norelease='1'
                        uci set network.wan.multipath='off'
                        # -----------------------
                    fi
                    
                    uci commit network; uci commit dhcp
                    log "向导: 上网配置已提交，准备接管并透传 Wi-Fi 配置任务..."
                    

                    # 2. 现成的 Wi-Fi 处理引擎
                    mode="wifi"
                    arg1="$arg2"
                fi
                # ==================================

                if [ "$mode" = "wan_dhcp" ]; then
                    cleanup_lan_for_wan_modes;
                    cleanup_wan_for_proto "dhcp"
                    uci set network.wan.proto='dhcp'
                    uci commit network; uci commit dhcp
                elif [ "$mode" = "wan_static" ]; then
                    cleanup_lan_for_wan_modes;
                    cleanup_wan_for_proto "static"
                    uci set network.wan.proto='static'
                    uci set network.wan.ipaddr="$arg1"
                    uci set network.wan.gateway="$arg2"
                    uci set network.wan.netmask="$arg3"
                    uci commit network; uci commit dhcp
                elif [ "$mode" = "pppoe" ]; then
                    cleanup_lan_for_wan_modes;
                    cleanup_wan_for_proto "pppoe"
                    uci set network.wan.proto='pppoe'
                    uci set network.wan.username="$arg1"
                    uci set network.wan.password="$arg2"

                    uci set network.wan.ipv6='auto'
                    uci set network.wan.norelease='1'
                    uci set network.wan.multipath='off'
                    # ----------------------------------------------
                    
                    uci commit network; uci commit dhcp

                # ==========================================
                # 拦截并静默处理向导状态的写入 (包含跳过/关闭时的劫持释放)
                elif [ "$mode" = "set_wizard" ]; then
                    log "静默修改向导弹出状态为: $arg1"
                    
                    # 确保文件存在，防止 uci 报错
                    [ ! -f /etc/config/netwiz ] && touch /etc/config/netwiz
                    
                    uci -q get netwiz.main >/dev/null 2>&1 || uci set netwiz.main=global
                    uci set netwiz.main.wizard_enable="$arg1"
                    
                    uci -q get netwiz.global >/dev/null 2>&1 || uci set netwiz.global=netwiz
                    uci set netwiz.global.configured='1'
                    
                    uci commit netwiz
                    
                    if [ -f /www/cgi-bin/luci.bak ]; then
                        log "释放底层 LuCI 强制劫持"
                        mv /www/cgi-bin/luci.bak /www/cgi-bin/luci
                    fi

                    echo '{"result":0}'
                    exit 0
                # ==========================================

                elif [ "$mode" = "lan" ]; then
                    
                    # LAN 口 120 秒安全模式防失联 (跨重启物理防砖)
                    if [ "$arg5" = "1" ]; then
                        log ">>> [LAN设置] 已启用 120 秒安全模式，生成物理防砖备份..."
                        cp -p /etc/config/network /etc/config/network.netwiz_bak 2>/dev/null
                        cp -p /etc/config/dhcp /etc/config/dhcp.netwiz_bak 2>/dev/null
                        touch /tmp/netwiz_rollback_time
                        
                        (
                            sleep 120
                            if [ -f "/tmp/netwiz_rollback_time" ]; then
                                logger -t Netwiz "[WATCHDOG] 🚨 LAN 120秒超时！前端未重连，执行回滚！"
                                echo "$(date '+%F %T') [WATCHDOG] 🚨 LAN口 120秒内未重连，触发安全回滚！" >> /etc/netwiz_recovery.log
                                cp -p /etc/config/network.netwiz_bak /etc/config/network 2>/dev/null
                                cp -p /etc/config/dhcp.netwiz_bak /etc/config/dhcp 2>/dev/null
                                /etc/init.d/network restart
                                /etc/init.d/dnsmasq restart
                                rm -f /tmp/netwiz_rollback_time
                            fi
                        ) </dev/null >/dev/null 2>&1 &
                    fi

                    uci set network.lan.proto='static'; uci set network.lan.ipaddr="$arg1"; uci set network.lan.netmask="$arg3"
                    if [ -n "$arg2" ]; then uci set network.lan.gateway="$arg2"; else uci delete network.lan.gateway 2>/dev/null || true; fi
                    if [ "$arg4" = "1" ]; then
                        uci set dhcp.lan.ignore='1'
                        [ -n "$arg2" ] && uci set network.lan.dns="$arg2"
                    else
                        uci set dhcp.lan.ignore='0'; uci delete network.lan.dns 2>/dev/null || true
                    fi
                    
                    # ==========================================
                    # IPv6 状态对齐与自愈
                    # ==========================================
                    current_v6=$(uci -q get dhcp.lan.dhcpv6) # 获取路由器当前真实的 IPv6 状态
                    
                    # 如前端明确要求开启 (arg6=1)，或者前端没传但底层原本就是开启的 (current_v6=server)
                    if [ "$arg6" = "1" ] || { [ -z "$arg6" ] && [ "$current_v6" = "server" ]; }; then
                        log ">>> [IPv6] 强制清洗并应用标准 DHCPv6 五重参数..."
                        # 1. 净化 ULA 前缀
                        uci -q delete network.globals.ula_prefix
                        
                        # 2. 确保 LAN 口拥有申请 IPv6 前缀的权限
                        uci set network.lan.ip6assign='60' 

                        # 3. 开启服务与通告
                        uci set dhcp.lan.dhcpv6='server'
                        uci set dhcp.lan.ra='server'
                        uci set dhcp.lan.ndp='server'
                        
                        # 4. 开启 SLAAC (增加安卓兼容性)
                        uci set dhcp.lan.ra_slaac='1'
                        
                        # 5. 注入 M-Flag 和 O-Flag (先删后加防重复)
                        uci -q del_list dhcp.lan.ra_flags='managed-config'
                        uci add_list dhcp.lan.ra_flags='managed-config'
                        uci -q del_list dhcp.lan.ra_flags='other-config'
                        uci add_list dhcp.lan.ra_flags='other-config'
                        
                        uci commit network
                        
                    elif [ "$arg6" = "0" ]; then
                        log ">>> [IPv6] 明确要求关闭，执行无痕清理..."
                        uci set dhcp.lan.dhcpv6='disabled'
                        uci set dhcp.lan.ra='disabled'
                        uci set dhcp.lan.ndp='disabled'
                        
                        uci -q delete dhcp.lan.ra_slaac
                        uci -q del_list dhcp.lan.ra_flags='managed-config'
                        uci -q del_list dhcp.lan.ra_flags='other-config'
                    fi
                    
                    uci commit dhcp
                    
                    uci commit network; uci commit dhcp
                elif [ "$mode" = "wifi" ]; then
                    payload="$arg1"
                    echo '{"result":0}'

                    # 放入后台执行 避免前端卡死
                    (
                        exec >/tmp/netwiz_debug.log 2>&1 </dev/null
                        set -x
                        log ">>> [步骤 1/5] 无线配置子进程启动，开始解析前端 Payload"
                        smart=$(echo "$payload" | jsonfilter -e '@.smart' || echo "false")
                        log "识别到智能模式状态: $smart"

                        list_2g=""
                        list_5g=""
                        dev_list=$(uci show wireless 2>/dev/null | grep '=wifi-device' | cut -d'.' -f2 | cut -d'=' -f1 || true)

                        if [ -z "$dev_list" ]; then
                            log "未找到无线网卡 终止操作"
                            exit 1
                        fi

                        # 解析物理网卡频段
                        for dev in $dev_list; do
                            hwmode=$(uci -q get wireless.$dev.hwmode | tr 'A-Z' 'a-z' || true)
                            band=$(uci -q get wireless.$dev.band | tr 'A-Z' 'a-z' || true)
                            path=$(uci -q get wireless.$dev.path || true)
                            is_5g=0
                            current_channel=$(uci -q get wireless.$dev.channel || echo "0")
                            current_ht=$(uci -q get wireless.$dev.htmode | tr 'A-Z' 'a-z' || echo "")

                            # Wi-Fi 6/7 (11ax/11be) 在 2.4G 频段的误判 Bug
                            if [ "$band" = "5g" ] || [ "$band" = "6g" ]; then is_5g=1
                            elif [ "$band" = "2g" ]; then is_5g=0
                            elif [ "$current_channel" != "0" ] && [ "$current_channel" != "auto" ] && [ "$current_channel" -ge 36 ]; then is_5g=1
                            elif [ "$current_channel" != "0" ] && [ "$current_channel" != "auto" ] && [ "$current_channel" -le 14 ]; then is_5g=0
                            elif echo "$current_ht" | grep -qE "80|160|320"; then is_5g=1
                            elif echo "$hwmode" | grep -qE "11a|11ac"; then is_5g=1
                            elif echo "$hwmode" | grep -qE "11b|11g"; then is_5g=0
                            else
                                # 没有明确特征，radio0 归 2.4G，其余归 5G
                                if echo "$dev" | grep -qE "radio0"; then is_5g=0; else is_5g=1; fi
                            fi

                            if [ "$is_5g" = "1" ]; then
                                list_5g="$list_5g $dev"
                            else
                                list_2g="$list_2g $dev"
                            fi
                        done

                        # 处理防重叠
                        if [ $(echo "$list_5g" | wc -w) -ge 2 ] && [ -z "$list_2g" ]; then
                            list_2g=$(echo $list_5g | awk '{print $1}')
                            list_5g=$(echo $list_5g | cut -d' ' -f2-)
                        elif [ $(echo "$list_2g" | wc -w) -ge 2 ] && [ -z "$list_5g" ]; then
                            list_5g=$(echo $list_2g | awk '{print $2}')
                            list_2g=$(echo $list_2g | awk '{print $1}')
                        fi

                        log ">>> [步骤 2/5] 网卡归类完毕。2.4G阵列: [$list_2g] | 5G阵列: [$list_5g]"
                        log "清空所有旧的无线网络接口"
                        while uci -q delete wireless.@wifi-iface[0]; do :; done

                        # 定义写网卡函数
                        configure_physical_radio() {
                            local dev="$1"
                            local ui_prefix="$2"
                            local iface_name="$3"
                            local intended_band="$4"
                            local ssid_suffix="$5"

                            local p_en=$(echo "$payload" | jsonfilter -e "@.${ui_prefix}.enabled" || echo "0")
                            local p_ssid=$(echo "$payload" | jsonfilter -e "@.${ui_prefix}.ssid" || echo "")
                            
                            # <--- 有后缀，自动追加到 SSID 尾部
                            if [ -n "$p_ssid" ] && [ -n "$ssid_suffix" ]; then
                                p_ssid="${p_ssid}${ssid_suffix}"
                            fi
                            local p_key=$(echo "$payload" | jsonfilter -e "@.${ui_prefix}.key" || echo "")
