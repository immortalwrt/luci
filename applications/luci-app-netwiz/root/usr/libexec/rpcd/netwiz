                    rm -rf /tmp/nw_sys_config.tar.gz /tmp/nw_offline_pkgs /tmp/nw_backup_running /tmp/nw_backup_meta.env
                    
                    chmod 644 "$backup_file"
                    ln -sf "$backup_file" "$link_file"
                    
                    sleep 300
                    rm -f "$backup_file" "$link_file"
 
                ) >/dev/null 2>&1 &

                printf '{"url":"/luci-static/%s", "filename":"%s"}\n' "$dl_name" "$dl_name"
                exit 0
                ;;

            check_backup)
                if [ -f "/tmp/nw_backup_running" ]; then
                    # 提取最后4行日志，并进行严格的JSON符号安全转义
                    log_safe=$(tail -n 4 /etc/netwiz_recovery.log 2>/dev/null | tr -d '\r' | sed 's/\\/\\\\/g; s/"/\\"/g' | awk '{printf "%s\\n", $0}' | sed 's/\\n$//')
                    
                    echo "{ \"status\": \"running\", \"log\": \"$log_safe\" }"
                elif [ -f "/tmp/nw_backup_ok" ]; then
                    # 依据真实状态锁宣告打包圆满成功，且将 opkg 转换为符合前端识别的 ipk 烙印
                    SYS_ARCH=$(uname -m)
                    PKG_TYPE="ipk"
                    command -v apk >/dev/null 2>&1 && PKG_TYPE="apk"
                    DATE_STR=$(date '+%Y%m%d_%H%M')
                    
                    FNAME="NetWiz_${SYS_ARCH}_${PKG_TYPE}_${DATE_STR}.tar.gz"
                    echo "{ \"status\": \"done\", \"url\": \"/luci-static/nw_sys_config.tar.gz\", \"filename\": \"$FNAME\" }"
                    rm -f "/tmp/nw_backup_ok"
                else
                    echo '{ "status": "error" }'
                fi
                exit 0
                ;;

            check_storage)
                # 动态获取 /tmp 的真实可用空间 (从 KB 转换为 MB)
                TMP_AVAIL_KB=$(df -k /tmp | awk 'END{print $(NF-2)}')
                TMP_AVAIL_MB=$((TMP_AVAIL_KB / 1024))
                printf '{"tmp_avail_mb": %d}\n' "$TMP_AVAIL_MB"
                exit 0
                ;;

            check_restore_status)
                # 读取恢复任务的实时状态，供前端进度条轮询
                if [ -f /tmp/nw_restore_status.json ]; then
                    cat /tmp/nw_restore_status.json
                else
                    printf '{"status":"unknown", "code":"MSG_RST_WAIT"}\n'
                fi
                exit 0
                ;;

            smart_restore_exec)
                input=$(cat)
                target_file=$(echo "$input" | jsonfilter -e '@.filepath')
                
                if [ -z "$target_file" ] || [ ! -s "$target_file" ]; then
                    target_file=$(ls -t /tmp/luci-upload-* /tmp/NetWiz_SmartGhost.tar.gz 2>/dev/null | head -n 1)
                fi

                if [ -n "$target_file" ] && [ -s "$target_file" ]; then
                    
                    # 初始化状态文件 (Code 机制)
                    echo '{"status":"running", "code":"MSG_RST_INIT"}' > /tmp/nw_restore_status.json
                    
                    cat << 'EOF' > /tmp/nw_do_restore.sh
#!/bin/sh
# 恢复操作需要重启，将核心日志写入实体存储
LOG_FILE="/etc/netwiz_recovery.log"
STATUS_FILE="/tmp/nw_restore_status.json"
TARGET="$1"

# 状态更新函数，使用状态码进行国际化传递，写入日志
update_status() {
    local stat="$1"
    local code="$2"
    local arg1="$3"
    local arg2="$4"
    echo "{\"status\":\"$stat\", \"code\":\"$code\", \"arg1\":\"$arg1\", \"arg2\":\"$arg2\"}" > "$STATUS_FILE"
    
    logger -t Netwiz "[RESTORE] $code $arg1 $arg2"
    echo "$(date '+%F %T') [RESTORE] $code $arg1 $arg2" >> "$LOG_FILE"
}

echo "$(date '+%F %T') [RESTORE] === 开始执行极速恢复 ===" >> "$LOG_FILE"

update_status "running" "MSG_RST_SCAN"

UNCOMPRESSED_BYTES=$(zcat "$TARGET" | wc -c 2>/dev/null)
UNCOMPRESSED_MB=$((UNCOMPRESSED_BYTES / 1024 / 1024))

TMP_AVAIL_KB=$(df -k /tmp | awk 'END{print $(NF-2)}')
TMP_AVAIL_MB=$((TMP_AVAIL_KB / 1024))

echo "$(date '+%F %T') [RESTORE] 预估体积: ${UNCOMPRESSED_MB}MB, 可用空间: ${TMP_AVAIL_MB}MB" >> "$LOG_FILE"

# 安全拦截：所需空间大于剩余空间时拦截
if [ $((UNCOMPRESSED_MB + 15)) -gt "$TMP_AVAIL_MB" ]; then
    update_status "error" "MSG_RST_OOM_INTERCEPT" "$UNCOMPRESSED_MB" "$TMP_AVAIL_MB"
    # 拦截后清理垃圾释放内存
    rm -f "$TARGET"
    exit 1
fi

update_status "running" "MSG_RST_SAFE"
mkdir -p /tmp/nw_ghost_tmp

# ----------------------------------------------------
# 防呆 3：拆包核对！先提取出元数据文件进行比对
# ----------------------------------------------------
echo "$(date '+%F %T') [RESTORE] 正在进行安全性预检：核对架构与安装包格式..." >> "$LOG_FILE"

# 只单独解压这一个配置文件，不触碰系统其他文件
# 从最外层瞬间抽离出指纹文件
tar -xzf "$TARGET" -C /tmp/nw_ghost_tmp nw_backup_meta.env >/dev/null 2>&1

if [ -f "/tmp/nw_ghost_tmp/nw_backup_meta.env" ]; then
    CUR_ARCH=$(uname -m)
    CUR_PKG="ipk"
    command -v apk >/dev/null 2>&1 && CUR_PKG="apk"
    
    # 仅读取外层提取的指纹数据，绝对不可访问内层路径。
    . /tmp/nw_ghost_tmp/nw_backup_meta.env
    
    if [ "$BACKUP_PKG" != "$CUR_PKG" ]; then
        echo "$(date '+%F %T') [RESTORE] [DANGER] 🚨 严重拦截：包管理器格式冲突！(当前: ${CUR_PKG} / 备份: ${BACKUP_PKG})" >> "$LOG_FILE"
        update_status "error" "MSG_RST_PKG_ERR"
        rm -rf /tmp/nw_ghost_tmp "$TARGET"
        exit 1
    fi
    
    if [ "$BACKUP_ARCH" != "$CUR_ARCH" ]; then
        echo "$(date '+%F %T') [RESTORE] [DANGER] 🚨 严重拦截：底层架构不匹配！(当前路由器: ${CUR_ARCH} / 备份包来源: ${BACKUP_ARCH})" >> "$LOG_FILE"
        update_status "error" "MSG_RST_ARCH_ERR"
        rm -rf /tmp/nw_ghost_tmp "$TARGET"
        exit 1
    fi
    
    echo "$(date '+%F %T') [RESTORE] ✅ 安全性预检通过！架构 (${CUR_ARCH}) 与包管理器 (${CUR_PKG}) 完全匹配。" >> "$LOG_FILE"
else
    echo "$(date '+%F %T') [RESTORE] ⚠️ 警告：这是一个旧版备份包 (未包含安全预检文件)，将跳过严格核对直接放行。" >> "$LOG_FILE"
fi
# ----------------------------------------------------

# 安全校验通过，执行真正的完整解压
tar -xzf "$TARGET" -C /tmp/nw_ghost_tmp >> "$LOG_FILE" 2>&1

if [ $? -ne 0 ]; then
    update_status "error" "MSG_RST_FAIL"
    rm -rf /tmp/nw_ghost_tmp "$TARGET"
    exit 1
fi

if [ ! -f "/tmp/nw_ghost_tmp/nw_sys_config.tar.gz" ] && [ ! -d "/tmp/nw_ghost_tmp/nw_offline_pkgs" ]; then
    update_status "error" "MSG_RST_INVALID"
    rm -rf /tmp/nw_ghost_tmp "$TARGET"
    exit 1
fi

if [ -f "/tmp/nw_ghost_tmp/nw_sys_config.tar.gz" ]; then
    update_status "running" "MSG_RST_CONF"
    
    # ==========================================
    # 【前置防御】启动跨重启防砖看门狗 (WAL 模式)
    # 此时已通过所有防呆检测，即将覆盖核心文件！标志物理护盾
    # ==========================================
    echo "$(date '+%F %T') [RESTORE] [安全防御] 正在将当前健康配置写入闪存，准备跨越重启防砖..." >> "$LOG_FILE"
    mkdir -p /etc/netwiz/failsafe
    cp -p /etc/config/network /etc/netwiz/failsafe/network_bak 2>/dev/null
    cp -p /etc/config/dhcp /etc/netwiz/failsafe/dhcp_bak 2>/dev/null
    cp -p /etc/config/wireless /etc/netwiz/failsafe/wireless_bak 2>/dev/null
    touch /etc/netwiz_pending_recovery
    # ==========================================

    # 护盾就绪，开始向系统根目录释放配置，这是“危险操作”
    tar -xzf /tmp/nw_ghost_tmp/nw_sys_config.tar.gz -C / >> "$LOG_FILE" 2>&1
fi

if [ -d "/tmp/nw_ghost_tmp/nw_offline_pkgs" ]; then
    update_status "running" "MSG_RST_PKGS"
    
    # --- 安装前删除除底层系统核心包，彻底杜绝依赖冲突中断 ---
    rm -f /tmp/nw_ghost_tmp/nw_offline_pkgs/firewall-* \
          /tmp/nw_ghost_tmp/nw_offline_pkgs/firewall4-* \
          /tmp/nw_ghost_tmp/nw_offline_pkgs/dnsmasq-* \
          /tmp/nw_ghost_tmp/nw_offline_pkgs/wpad-* \
          /tmp/nw_ghost_tmp/nw_offline_pkgs/base-files-* \
          /tmp/nw_ghost_tmp/nw_offline_pkgs/libc-* 2>/dev/null
    # ---------------------------------------------------------------
    
    # 全局剔除包含 netwiz / NetWiz 的安装包，防止重启 rpcd 导致脚本自杀
    rm -f /tmp/nw_ghost_tmp/nw_offline_pkgs/*[nN]et[wW]iz*.[ia]pk 2>/dev/null
    rm -f /etc/netwiz/custom_pkgs/*[nN]et[wW]iz*.[ia]pk 2>/dev/null
    
    # ==========================================
    # 防呆检测：跨架构 (ipk <-> apk) 拦截机制
    # ==========================================
    
    if command -v apk >/dev/null 2>&1; then
        # 当前系统为 apk，检测备份包中是否包含旧版 ipk
        if ls /tmp/nw_ghost_tmp/nw_offline_pkgs/*.ipk >/dev/null 2>&1 || ls /etc/netwiz/custom_pkgs/*.ipk >/dev/null 2>&1; then
            logger -t Netwiz "[RESTORE] [DANGER] 触发智能防呆：当前为 apk 系统，拦截到 ipk 安装包！"
            echo "$(date '+%F %T') [RESTORE] [DANGER] 🚨 触发智能防呆：当前系统使用 apk (Alpine)，但备份胶囊中检测到不兼容的 ipk 安装包！" >> "$LOG_FILE"
            echo "$(date '+%F %T') [RESTORE] [DANGER] 已自动拦截并跳过所有插件的还原，以防止底层架构损坏！请重新下载对应 apk 版本的插件放入保险箱。" >> "$LOG_FILE"
        else
            echo "$(date '+%F %T') [RESTORE] >>> 系统架构匹配 (apk)，开始恢复插件..." >> "$LOG_FILE"
            if ls /tmp/nw_ghost_tmp/nw_offline_pkgs/*.apk >/dev/null 2>&1; then
                apk add --allow-untrusted --force-overwrite /tmp/nw_ghost_tmp/nw_offline_pkgs/*.apk >> "$LOG_FILE" 2>&1
            fi
            if ls /etc/netwiz/custom_pkgs/*.apk >/dev/null 2>&1; then
                apk add --allow-untrusted --force-overwrite /etc/netwiz/custom_pkgs/*.apk >> "$LOG_FILE" 2>&1
            fi
        fi

    elif command -v opkg >/dev/null 2>&1; then
        # 当前系统为 opkg，检测备份包中是否包含新版 apk
        if ls /tmp/nw_ghost_tmp/nw_offline_pkgs/*.apk >/dev/null 2>&1 || ls /etc/netwiz/custom_pkgs/*.apk >/dev/null 2>&1; then
            logger -t Netwiz "[RESTORE] [DANGER] 触发智能防呆：当前为 opkg 系统，拦截到 apk 安装包！"
            echo "$(date '+%F %T') [RESTORE] [DANGER] 🚨 触发智能防呆：当前系统使用 opkg，但备份胶囊中检测到不兼容的 apk 安装包！" >> "$LOG_FILE"
            echo "$(date '+%F %T') [RESTORE] [DANGER] 已自动拦截并跳过所有插件的还原，以防止底层架构损坏！请重新下载对应 ipk 版本的插件放入保险箱。" >> "$LOG_FILE"
        else
            echo "$(date '+%F %T') [RESTORE] >>> 系统架构匹配 (opkg)，开始恢复插件..." >> "$LOG_FILE"
            
            if ls /tmp/nw_ghost_tmp/nw_offline_pkgs/*.ipk >/dev/null 2>&1; then
                opkg install --force-reinstall --force-overwrite /tmp/nw_ghost_tmp/nw_offline_pkgs/*.ipk >> "$LOG_FILE" 2>&1
            fi
            if ls /etc/netwiz/custom_pkgs/*.ipk >/dev/null 2>&1; then
                opkg install --force-reinstall --force-overwrite /etc/netwiz/custom_pkgs/*.ipk >> "$LOG_FILE" 2>&1
            fi
        fi
    fi
fi

# 提取备份中 LAN IP
NEW_IP=$(uci -q get network.lan.ipaddr | cut -d/ -f1)

# 把未来的新 IP 作为 arg1 传递给前端进行双向探测
update_status "done" "MSG_RST_DONE" "$NEW_IP"
rm -rf /tmp/nw_ghost_tmp "$TARGET"

echo "$(date '+%F %T') [RESTORE] >>> 恢复任务全部完成！系统即将重启。" >> "$LOG_FILE"

# 等待 8 秒，确保前端 充足的时间抓取新 IP
sleep 8
reboot
EOF
                    chmod +x /tmp/nw_do_restore.sh
                    /tmp/nw_do_restore.sh "$target_file" >/dev/null 2>&1 &
                    
                    echo '{"result":0}'
                else
                    echo '{"error":"No data"}'
                fi
                exit 0
                ;;
        esac
        ;;
esac
exit 1
