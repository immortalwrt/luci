case "$1" in
    list)
        echo '{ "get_list": { "show_conns": "boolean" }, "bind": { "mac": "string", "ip": "string", "name": "string", "dept": "string", "no_reload": "boolean" }, "unbind": { "mac": "string", "no_reload": "boolean" }, "wake_device": { "mac": "string" }, "apply_dhcp": {}, "get_depts": {}, "save_depts": { "data": "string" }, "get_smart_ranges": {}, "save_smart_ranges": { "data": "string" }, "v6_keep_alive": { "mac": "string", "name": "string" }, "reset_all": {}, "analyze_conns": { "ip": "string" }, "export_config": {}, "import_config": { "data": "string", "file": "string" }, "list_backups": {}, "auto_backup": {}, "fw_set": { "mac": "string", "ip": "string", "blk_en": "boolean", "iso_en": "boolean", "dmz_en": "boolean" } }'
        exit 0
        ;;
    call)
        case "$2" in
            get_list)
                input=$(cat)
                show_conns=$(echo "$input" | jsonfilter -e '@.show_conns' || echo "false")
                do_rescan=$(echo "$input" | jsonfilter -e '@.do_rescan' || echo "false")
                
                # --- 主动唤醒扫描 ---
                if [ "$do_rescan" = "true" ] || [ "$do_rescan" = "1" ]; then
                    # 动态取得 LAN 网段
                    lan_prefix=$(uci -q get network.lan.ipaddr | cut -d. -f1-3)
                    if [ -n "$lan_prefix" ]; then
                        # Ping 封包，取MAC
                        for i in $(seq 1 254); do
                            (ping -c 1 -W 1 -q "$lan_prefix.$i" >/dev/null 2>&1) &
                        done
                        
                        # --- 向多播地址和 APIPA 广播，169.254 自闭设备现身 ---
                        (ping -c 1 -W 1 -q 224.0.0.1 >/dev/null 2>&1) &
                        (ping -c 1 -W 1 -I br-lan 169.254.255.255 >/dev/null 2>&1) &
                        # -----------------------------------------------------------
                        
                        # 等待 1 秒写入 ARP 表
                        sleep 1
                    fi
                fi
                # ----------------------------------------
                
                rm -f /tmp/nw_conns_cache.txt
                touch /tmp/nw_conns_cache.txt
                if [ "$show_conns" = "true" ] || [ "$show_conns" = "1" ]; then
                    if [ -f /proc/net/nf_conntrack ]; then
                        awk '{src="";proto=$3;dport=0;s_done=0;d_done=0; for(i=1;i<=NF;i++){if(!s_done && $i~/^src=/){split($i,a,"=");src=a[2];s_done=1;} if(!d_done && $i~/^dport=/){split($i,a,"=");dport=a[2]+0;d_done=1;} if(s_done && d_done) break;} if(src!=""){t[src]++;if(dport==80||dport==443)w[src]++;else if(dport==53||dport==5353||dport==123)d[src]++;else if(proto=="udp")u[src]++;else if(dport>10000)p[src]++;else o[src]++;}} END{for(i in t) print i"="t[i]","w[i]+0","d[i]+0","u[i]+0","p[i]+0","o[i]+0}' /proc/net/nf_conntrack 2>/dev/null > /tmp/nw_conns_cache.txt
                    elif command -v conntrack >/dev/null 2>&1; then
                        conntrack -L 2>/dev/null | awk '{src="";proto=$3;dport=0;s_done=0;d_done=0; for(i=1;i<=NF;i++){if(!s_done && $i~/^src=/){split($i,a,"=");src=a[2];s_done=1;} if(!d_done && $i~/^dport=/){split($i,a,"=");dport=a[2]+0;d_done=1;} if(s_done && d_done) break;} if(src!=""){t[src]++;if(dport==80||dport==443)w[src]++;else if(dport==53||dport==5353||dport==123)d[src]++;else if(proto=="udp")u[src]++;else if(dport>10000)p[src]++;else o[src]++;}} END{for(i in t) print i"="t[i]","w[i]+0","d[i]+0","u[i]+0","p[i]+0","o[i]+0}' > /tmp/nw_conns_cache.txt
                    fi
                fi

                fw_str=$(uci show firewall 2>/dev/null || true)
                ipv6_neigh=$(ip -6 neigh show 2>/dev/null || true)
                
                # --- IPv6 存活探测过滤 ---
                raw_v6_data=$(ip -6 neigh show 2>/dev/null | grep -v "FAILED")
                v6_candidates=$(echo "$raw_v6_data" | awk '{print $1}' | grep ":" | sort -u)
                
                # 1. 删除 邻居表公网 IPv6
                for v6_addr in $v6_candidates; do
                    if [[ "$v6_addr" != fe80* ]]; then
                        # 找到网卡
                        dev_name=$(echo "$raw_v6_data" | grep -w "^$v6_addr" | awk '{print $3}' | head -n 1)
                        [ -n "$dev_name" ] && ip -6 neigh del "$v6_addr" dev "$dev_name" 2>/dev/null
                    fi
                done
                
                # 2. Ping
                for v6_addr in $v6_candidates; do
                    if [[ "$v6_addr" != fe80* ]]; then
                        ping6 -c 1 -W 1 "$v6_addr" >/dev/null 2>&1 &
                    fi
                done
                wait
                
                # 3. 延时
                sleep 0.5
                
                # 4. 重新抓取邻居表
                ipv6_neigh=$(ip -6 neigh show 2>/dev/null | grep -v -E "FAILED|INCOMPLETE" || true)
                # --------------------------
                wifi_macs=$(iwinfo 2>/dev/null | grep -o -E '([[:xdigit:]]{1,2}:){5}[[:xdigit:]]{1,2}' | tr 'A-Z' 'a-z' || true)
                arp_cache=$(ip -4 neigh show 2>/dev/null || cat /proc/net/arp 2>/dev/null | tail -n +2 || true)
                leases=$(cat /tmp/dhcp.leases /var/dhcp.leases /tmp/run/dnsmasq/dhcp.leases /var/lib/misc/dnsmasq.leases 2>/dev/null || true)
                hosts_str=$(cat /tmp/hosts/* /etc/hosts 2>/dev/null || true)
                uci_hosts=$(uci show dhcp 2>/dev/null | grep "\.@host\[" || true)
                ubus_leases=$(ubus call dhcp ipv4leases 2>/dev/null || ubus call odhcpd ipv4leases 2>/dev/null || true)
                gw_ip=$(ip -4 route show default 2>/dev/null | awk '/default/ {print $3}' | head -n1 | tr -d ' \r\n')
                lan_ip=$(ip addr show br-lan 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | head -n1 | tr -d ' \r\n')
                [ -z "$lan_ip" ] && lan_ip=$(uci -q get network.lan.ipaddr | cut -d/ -f1 | tr -d ' \r\n')
                lan_mac=$(ip link show br-lan 2>/dev/null | awk '/link\/ether/ {print $2}' | head -n1 | tr 'A-Z' 'a-z')
                [ -z "$lan_mac" ] && lan_mac=$(ip link | awk '/link\/ether/ {print $2}' | head -n1 | tr 'A-Z' 'a-z')
                local_ips=$(ip -4 addr show 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | tr '\n' ' ')
                visitor_ips=$(netstat -nt 2>/dev/null | awk '$4 ~ /:(80|443)$/ && $6 ~ /ESTABLISHED/ {split($5, a, ":"); if(a[1]!="") print a[1]}' | sort -u | tr '\n' ' ')
                curr_time=$(date +%s)

                # --- IPv6 与 LAN NAT 冲突检测 ---
                lan_zone_idx=$(uci show firewall 2>/dev/null | grep -E "\.name='?lan'?" | cut -d'.' -f2 | head -n 1)
                lan_nat_conflict="false"
                if [ -n "$lan_zone_idx" ]; then
                    lan_masq=$(uci -q get firewall.$lan_zone_idx.masq)
                    if [ "$lan_masq" = "1" ]; then
                        lan_nat_conflict="true"
                    fi
                fi
                
                # 后端查 IPv6 有没有开
                ipv6_enabled="false"
                v6_dhcp=$(uci -q get dhcp.lan.dhcpv6)
                if [ "$v6_dhcp" = "server" ] || [ "$v6_dhcp" = "relay" ]; then
                    ipv6_enabled="true"
                fi
                # ------------------------------------------

                # 提取本机活跃的全局 IPv6 地址 (排除 fd/fe80 等内网或链路地址)
                lan_ip6=$(ip -o -6 addr show br-lan scope global 2>/dev/null | grep -v "deprecated" | grep -v " fd" | awk '{print $4}' | cut -d/ -f1 | tr '\n' ' ' | sed 's/ $//')

                # 注意：下面这一行多加了一个传参 -v lan_ip6="$lan_ip6"
                json_data=$(awk -v current_time="$curr_time" -v lan_nat_conflict="$lan_nat_conflict" -v ipv6_enabled="$ipv6_enabled" -v wifi_str="$wifi_macs" -v arp_str="$arp_cache" -v lease_str="$leases" -v hosts_str="$hosts_str" -v ubus_str="$ubus_leases" -v uci_str="$uci_hosts" -v gw_ip="$gw_ip" -v lan_ip="$lan_ip" -v lan_ip6="$lan_ip6" -v lan_mac="$lan_mac" -v local_ips_str="$local_ips" -v visitor_ips_str="$visitor_ips" -v fw_str_input="$fw_str" -v ipv6_str="$ipv6_neigh" '
                BEGIN {
                    now_ts = current_time;
                    exp_ts = 2592000; # 30天过期时间
                    while ("uci -q show netwiz 2>/dev/null" | getline cfg_line) {
                        if (index(cfg_line, "netwiz.seen_") == 1 || index(cfg_line, "netwiz.v6pc_") == 1) {
                                split(cfg_line, eq_parts, "=");
                                split(eq_parts[1], dot_parts, ".");
                                split(dot_parts[2], _parts, "_");
                                _mac_clean = tolower(_parts[2]);
                                if (length(_mac_clean) == 12) {
                                    _m = substr(_mac_clean,1,2) ":" substr(_mac_clean,3,2) ":" substr(_mac_clean,5,2) ":" substr(_mac_clean,7,2) ":" substr(_mac_clean,9,2) ":" substr(_mac_clean,11,2);
                                    in_config_map[_m] = 1;
                                }
                            }
                        if (index(cfg_line, "netwiz.v6pc_") == 1) {
                            split(cfg_line, eq_parts, "=");
                            if (eq_parts[2] != "") {
                                key_part = eq_parts[1]; val_part = eq_parts[2]; gsub(/[\047"\r\n]/, "", val_part);
                                split(key_part, dot_parts, "."); sec_name = dot_parts[2]; prop_name = dot_parts[3];
                                if (prop_name == "mac") uci_pc_macs[sec_name] = tolower(val_part);
                                else if (prop_name == "ts") uci_pc_ts[sec_name] = val_part + 0;
                                else if (prop_name == "hostname") uci_pc_name[sec_name] = val_part;
                            }
                        }
                    }
                    # 只有在30天以内的，才给它打上“PC”的身份标签
                    for (sec in uci_pc_macs) {
                        if (now_ts - uci_pc_ts[sec] <= exp_ts) is_pc_v6_map[uci_pc_macs[sec]] = 1;
                    }
                    close("uci -q show netwiz 2>/dev/null");

                    gsub(/^[ \t\r\n]+|[ \t\r\n]+$/, "", gw_ip);
                    gsub(/^[ \t\r\n]+|[ \t\r\n]+$/, "", lan_ip);
                    gsub(/^[ \t\r\n]+|[ \t\r\n]+$/, "", lan_mac);
                    
                    split(local_ips_str, lip_arr, " ");
                    for(i in lip_arr) if(lip_arr[i] != "" && lip_arr[i] != "127.0.0.1") router_ips[lip_arr[i]] = 1;

                    split(visitor_ips_str, vip_arr, " ");
                    for(i in vip_arr) if(vip_arr[i] != "" && vip_arr[i] != "127.0.0.1") visitor_ips[vip_arr[i]] = 1;

                    if (lan_mac != "" && lan_ip != "") {
                        all_macs[lan_mac] = 1;
                        arp_ip[lan_mac] = lan_ip; arp_online[lan_mac] = 1; ubus_name[lan_mac] = "OpenWrt (Local)";
                        # 本机的 IPv6 写入字典，弥补邻居表中可能缺失的情况
                        if (lan_ip6 != "") ipv6_map[lan_mac] = lan_ip6;
                    }

                    split(wifi_str, warr, "\n");
                    for(i in warr) if(warr[i]!="") wifi_online[warr[i]]=1;
                    
                    split(ipv6_str, v6arr, "\n");
                    for(i in v6arr) {
                        n_f = split(v6arr[i], f, " ");
                        if(f[1]!="" && f[1]!~/dev/) {
                            v6_ip = f[1]; mac = ""; state_str = v6arr[i];
                            for(j=1; j<=n_f; j++) {
                                if(f[j]=="lladdr" && n_f>=j+1) mac=tolower(f[j+1]);
                                else if(f[j] ~ /^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$/) mac=tolower(f[j]);
                            }
                            if(mac!="" && mac!="00:00:00:00:00:00" && state_str!~/FAILED/) {
                                if(ipv6_map[mac]=="") ipv6_map[mac] = v6_ip;
                                else if(index(ipv6_map[mac], v6_ip) == 0) ipv6_map[mac] = ipv6_map[mac] " " v6_ip;
                                all_macs[mac]=1;
                                if(state_str ~ /REACHABLE|DELAY|PROBE|router/) arp_online[mac]=1;
                            }
                        }
                    }

                    split(arp_str, aarr, "\n");
                    for(i in aarr) {
                        n_f = split(aarr[i], f, " ");
                        if(f[1]!="" && f[1]!~/IP/) {
                            mac=""; state_str=aarr[i];
                            for(j=1; j<=n_f; j++) {
                                if(f[j]=="lladdr" && n_f>=j+1) mac=tolower(f[j+1]);
                                else if(f[j] ~ /^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$/) mac=tolower(f[j]);
                            }
                            if(mac!="" && mac!="00:00:00:00:00:00") {
                                if (f[1] ~ /^169\.254\./) {
                                    if (arp_ip[mac] == "") arp_ip[mac] = f[1];
                                } else {
                                    arp_ip[mac] = f[1];
                                }
                                if(state_str ~ /REACHABLE|DELAY|PROBE|0x2/) arp_online[mac]=1;
                                all_macs[mac]=1;
                            }
                        }
                    }

                    split(ubus_str, ulines, "\n");
                    cur_mac = ""; cur_ip = ""; cur_name = ""; cur_valid = -1;
                    for(i=1; i<=length(ulines); i++) {
                        line = ulines[i];
                        if (line ~ /"mac":/) { split(line, p, "\""); cur_mac = tolower(p[4]); }
                        else if (line ~ /"ip":/) { split(line, p, "\""); cur_ip = p[4]; }
                        else if (line ~ /"hostname":/) { split(line, p, "\""); cur_name = p[4]; }
                        else if (line ~ /"valid":/ || line ~ /"expires":/ || line ~ /"leasetime":/) { 
                            split(line, p, ":"); val=p[2]; gsub(/[^0-9]/, "", val); val = val + 0; 
                            if (val > 1000000000) { cur_valid = (val > current_time) ? val - current_time : 0; }
                            else { cur_valid = val; }
                        }
                        else if (line ~ /}/) {
                            if (cur_mac != "") {
                                if (cur_ip != "") leases_ip[cur_mac] = cur_ip;
                                if (cur_name != "" && cur_name != "*" && cur_name != "?") ubus_name[cur_mac] = cur_name;
                                if (cur_valid > 0) {
                                    h = int(cur_valid / 3600); m = int((cur_valid % 3600) / 60); s = cur_valid % 60;
                                    leases_time[cur_mac] = sprintf("%dh %dm %ds", h, m, s);
                                } else if (cur_valid == 0) { leases_time[cur_mac] = "Expired"; }
                                all_macs[cur_mac] = 1;
                            }
                            cur_mac = ""; cur_ip = ""; cur_name = ""; cur_valid = -1;
                        }
                    }

                    split(lease_str, larr, "\n");
                    for(i in larr) {
                        n_f = split(larr[i], f, " ");
                        if(n_f >= 4 && f[2]!="") { 
                            # 忽略 dhcp.leases 中的 IPv6 租期，防止過期的死 IP 出现
                            if (f[3] ~ /:/) {
                                continue;
                            }
                            
                            # 原本的 IPv4 解析邏輯保持完全不變
                            mac=tolower(f[2]);
                            if(f[3]!="") leases_ip[mac]=f[3]; 
                            name = f[4];
                            for(k=5; k<=n_f-1; k++) { name = name " " f[k]; }
                            if(name!="" && name!="*" && name!="?") leases_name[mac]=name;
                            all_macs[mac]=1; 
                            exp_time = f[1] + 0;
                            if (leases_time[mac] == "") {
                                if (exp_time > 1000000000) {
                                    if (exp_time > current_time) {
                                        left = exp_time - current_time;
                                        h = int(left / 3600); m = int((left % 3600) / 60); s = left % 60;
                                        leases_time[mac] = sprintf("%dh %dm %ds", h, m, s);
                                    } else leases_time[mac] = "Expired";
                                } else if (exp_time > 0 && exp_time <= 1000000000) {
                                    left = exp_time;
                                    h = int(left / 3600); m = int((left % 3600) / 60); s = left % 60;
                                    leases_time[mac] = sprintf("%dh %dm %ds", h, m, s);
                                } else if (exp_time == 0) leases_time[mac] = "Infinite";
                            }
                        }
                    }

                    split(hosts_str, harr, "\n");
                    for(i in harr) {
                        split(harr[i], f, " ");
                        if(f[1]!="" && f[2]!="") {
                            if (f[1] ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/) {
                                name = f[2]; sub(/\.lan$/, "", name);
                                if (name != "localhost" && name != "*" && name != "?") ip_to_name[f[1]] = name;
                            }
                        }
                    }

                    split(uci_str, uarr, "\n");
                    for(i in uarr) {
                        idx=index(uarr[i],"=");
                        if(idx>0) {
                            key=substr(uarr[i],1,idx-1); val=substr(uarr[i],idx+1); gsub(/^\047|\047$/, "", val);
                            split(key, kp, ".");
                            if(kp[1]=="dhcp" && kp[2]!="" && kp[3]!="") {
                                h_idx=kp[2]; prop=kp[3];
                                if(prop=="mac"){
                                    gsub(/["\r\n]/, "", val); split(tolower(val), mparts, " "); 
                                    for(m in mparts) uci_mac_list[h_idx] = (uci_mac_list[h_idx]=="" ? "" : uci_mac_list[h_idx] " ") mparts[m];
                                }
                                else if(prop=="ip") uci_ip_map[h_idx]=val;
                                else if(prop=="name") uci_name_map[h_idx]=val;
                                else if(prop=="netwiz_dept") uci_dept_map[h_idx]=val;
                            }
                        }
                    }

                    for (h_idx in uci_mac_list) {
                        split(uci_mac_list[h_idx], mparts, " ");
                        for (m in mparts) {
                            m_mac = mparts[m]; all_macs[m_mac] = 1; is_static_mac[m_mac] = 1;
                            if (uci_ip_map[h_idx] != "") static_ip[m_mac] = uci_ip_map[h_idx];
