[ ! -f /etc/config/netwiz ] && {
    touch /etc/config/netwiz
    uci -q batch <<EOF
        set netwiz.global=netwiz
        set netwiz.smart=netwiz
        commit netwiz
EOF
}

delete_fw_rule() {
    local target_name="$1"
    local sec_type="${2:-rule}"
    local matches=$(uci -q show firewall 2>/dev/null | grep "^firewall\.@${sec_type}\[[0-9]*\]\.name=.*$target_name" | cut -d'.' -f2 | sed 's/[^0-9]//g' | sort -rn)
    for idx in $matches; do
        uci -q delete firewall.@${sec_type}[$idx]
    done
}

# --- 高级应用唤醒函數 ---
wakeup_apps() {
    local proxy_apps="openclash passwall shadowsocksr bypass vssr homeproxy mihomo"
    local dns_apps="adguardhome smartdns mosdns"
    
    # 1. 喚醒 DNS 类
    for app in $dns_apps; do
        if [ -x "/etc/init.d/$app" ] && /etc/init.d/$app enabled >/dev/null 2>&1; then
            logger -t Netwiz "⚡ Re-linking DNS app: $app"
            /etc/init.d/$app restart >/dev/null 2>&1
        fi
    done

    # 2. 喚醒 代理/加速
    for app in $proxy_apps; do
        if [ -x "/etc/init.d/$app" ] && /etc/init.d/$app enabled >/dev/null 2>&1; then
            logger -t Netwiz "🚀 Re-linking Proxy app: $app"
            /etc/init.d/$app restart >/dev/null 2>&1
        fi
    done
}
