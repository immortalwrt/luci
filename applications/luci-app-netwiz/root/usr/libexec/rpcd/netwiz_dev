# --- 提取设备 DUID 函數 ---
extract_device_duid() {
    local target_mac="$1"
    local target_clean=$(echo "$target_mac" | tr -d ':' | tr 'A-Z' 'a-z')
    local out_duid=""

    # 1. DHCPv6 底层数据中没有 MAC, 通过 IPv4 租约作为桥梁，用 MAC 换取 Hostname
    local host_name=$(cat /tmp/dhcp.leases 2>/dev/null | grep -i "$target_mac" | awk '{print $4}' | grep -v '^\*$' | head -n 1)
    local host_name_lower=$(echo "$host_name" | tr 'A-Z' 'a-z')

    local ubus1=$(ubus call dhcp ipv6leases 2>/dev/null)
    local ubus2=$(ubus call odhcpd ipv6leases 2>/dev/null)
    local raw_ubus="$ubus1 $ubus2"
    
    if [ -n "$raw_ubus" ]; then
        # 优先用 Hostname 桥接寻找 DUID (100% 精准锁定)
        if [ -n "$host_name_lower" ]; then
            out_duid=$(echo "$raw_ubus" | awk -v RS="}" -v hname="$host_name_lower" '
            tolower($0) ~ "\"" hname "\"" {
                idx = index(tolower($0), "\"duid\"");
                if (idx > 0) {
                    s = substr($0, idx);
                    split(s, a, "\"");
                    print a[4];
                    exit;
                }
            }' | tr 'A-Z' 'a-z' | head -n 1)
        fi
        
        # 如果 Hostname 没找到，尝试在 DUID 中直接寻找包含 MAC 字符串的情况
        if [ -z "$out_duid" ]; then
            out_duid=$(echo "$raw_ubus" | awk -v RS="}" -v mac="$target_clean" '
            tolower($0) ~ mac {
                idx = index(tolower($0), "\"duid\"");
                if (idx > 0) {
                    s = substr($0, idx);
                    split(s, a, "\"");
                    print a[4];
                    exit;
                }
            }' | tr 'A-Z' 'a-z' | head -n 1)
        fi
    fi
    
    # 2. odhcpd 底层状态文件 (同样用 Hostname 桥接)
    if [ -z "$out_duid" ] && ls /var/lib/odhcpd/*.state >/dev/null 2>&1; then
        if [ -n "$host_name" ]; then
            out_duid=$(grep -i "$host_name" /var/lib/odhcpd/*.state 2>/dev/null | grep -oEi 'duid=[0-9a-fA-F]+' | awk -F'=' '{print $2}' | head -n 1 | tr 'A-Z' 'a-z')
        fi
        [ -z "$out_duid" ] && out_duid=$(grep -i "$target_clean" /var/lib/odhcpd/*.state 2>/dev/null | grep -oEi 'duid=[0-9a-fA-F]+' | awk -F'=' '{print $2}' | head -n 1 | tr 'A-Z' 'a-z')
    fi
    
    echo "$out_duid"
}
