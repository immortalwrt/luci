            apply_dhcp)
                uci commit dhcp
                uci commit firewall
                
                # 清理 odhcpd 缓存
                rm -f /tmp/hosts/odhcpd 2>/dev/null
                
                (
                    /etc/init.d/odhcpd restart
                    /etc/init.d/dnsmasq restart
                    /etc/init.d/firewall reload
                    
                    sleep 2
                    wakeup_apps
                ) >/dev/null 2>&1 &
                
                echo '{"result":0}'
                exit 0
                ;;

            get_depts)
                val=$(uci -q get netwiz.global.depts_json)
                [ -z "$val" ] && val="[]"
                echo "{\"depts\": $val}"
                exit 0
                ;;

            save_depts)
                input=$(cat)
                json_str=$(echo "$input" | jsonfilter -e '@.data')
                uci -q delete netwiz.global
                uci set netwiz.global=netwiz
                uci set netwiz.global.depts_json="$json_str"
        
                uci commit netwiz
                echo '{"result":0}'
                exit 0
                ;;

                get_smart_ranges)
                val=$(uci -q get netwiz.smart.ranges_json)
                [ -z "$val" ] && val="{}"
                echo "{\"ranges\": $val}"
                exit 0
                ;;
            save_smart_ranges)
                input=$(cat)
                json_str=$(echo "$input" | jsonfilter -e '@.data')
                uci -q set netwiz.smart=netwiz
                if [ "$json_str" = "{}" ] || [ -z "$json_str" ]; then
                    uci -q delete netwiz.smart.ranges_json
                else
                    uci -q set netwiz.smart.ranges_json="$json_str"
                fi
                uci commit netwiz
                echo '{"result":0}'
                exit 0
                ;;

            v6_keep_alive)
                input=$(cat)
                mac=$(echo "$input" | jsonfilter -e '@.mac' | tr 'A-Z' 'a-z')
                name=$(echo "$input" | jsonfilter -e '@.name')
                [ -z "$mac" ] && exit 0

                MAC_SAFE=$(echo "$mac" | tr -d ':' | tr 'a-z' 'A-Z')
                NOW=$(date +%s)
                UPDATE_THRESHOLD=604800 # 7天

                OLD_TS=$(uci -q get netwiz.v6pc_$MAC_SAFE.ts)
                OLD_DUID=$(uci -q get netwiz.v6pc_$MAC_SAFE.duid)
                OLD_NAME=$(uci -q get netwiz.v6pc_$MAC_SAFE.hostname)
                live_duid=$(extract_device_duid "$mac")

                NEEDS_UPDATE=0
                # 1. 超过7天没更新时间戳
                [ -z "$OLD_TS" ] || [ $((NOW - OLD_TS)) -gt $UPDATE_THRESHOLD ] && NEEDS_UPDATE=1
                
                # 2. 抓到 DUID，且和以前保存的不一样
                [ -n "$live_duid" ] && [ "$live_duid" != "$OLD_DUID" ] && NEEDS_UPDATE=1
                
                # 3. 传来了新名字，且不是 Unknown，且和以前保存的不一样
                if [ -n "$name" ] && [ "$name" != "Unknown" ]; then
                    safe_name=$(echo "$name" | sed 's/[^a-zA-Z0-9_-]//g')
                    [ -n "$safe_name" ] && [ "$safe_name" != "$OLD_NAME" ] && NEEDS_UPDATE=1
                fi

                # 不一样时才写入闪存
                if [ "$NEEDS_UPDATE" -eq 1 ]; then
                    uci -q set netwiz.v6pc_$MAC_SAFE=v6_pc
                    uci -q set netwiz.v6pc_$MAC_SAFE.mac="$mac"
                    uci -q set netwiz.v6pc_$MAC_SAFE.ts="$NOW"
                    
                    [ -n "$live_duid" ] && uci -q set netwiz.v6pc_$MAC_SAFE.duid="$live_duid"
                    [ -n "$safe_name" ] && uci -q set netwiz.v6pc_$MAC_SAFE.hostname="$safe_name"
                    
                    uci -q delete netwiz.seen_$MAC_SAFE
                    uci commit netwiz
                fi
                
                echo '{"result":0}'
                exit 0
                ;;
                
            reset_all)
                # 初始化前备份
                mkdir -p /root/netwiz_bak
                backup_file="/root/netwiz_bak/netwiz_pre_reset_$(date +%Y%m%d_%H%M%S).tar.gz"
                
                FILE_LIST=""
                    for f in network wireless dhcp firewall netwiz; do
                        if [ -s "/etc/config/$f" ]; then FILE_LIST="$FILE_LIST etc/config/$f"; fi
                    done
                    tar -czf "$backup_file" -C / $FILE_LIST 2>/dev/null    
                
                logger -t Netwiz "📦 Pre-reset backup created: $backup_file"

                # 1. 净化防火墙
                for rule in $(uci -q show firewall 2>/dev/null | grep "^firewall\.@rule\[[0-9]*\]\.name=.*nw_" | cut -d'.' -f2 | sed 's/[^0-9]//g' | sort -rn | uniq);
                do 
                    uci -q delete firewall.@rule[$rule]
                done
                for redir in $(uci -q show firewall 2>/dev/null | grep "^firewall\.@redirect\[[0-9]*\]\.name=.*nw_dmz_" | cut -d'.' -f2 | sed 's/[^0-9]//g' | sort -rn | uniq);
                do 
                    uci -q delete firewall.@redirect[$redir]
                done
                uci commit firewall

                # 2. 净化 DHCP (删除所有的静态 IP 绑定)
                for host in $(uci -q show dhcp 2>/dev/null | grep "^dhcp\.@host\[[0-9]*\]=host" | cut -d'.' -f2 | sed 's/[^0-9]//g' | sort -rn | uniq);
                do
                    uci -q delete dhcp.@host[$host]
                done
                uci commit dhcp

                # 3. 淨化 Netwiz 配置
                rm -f /etc/config/netwiz
                touch /etc/config/netwiz
                uci -q batch <<EOF
                    set netwiz.global=netwiz
                    set netwiz.smart=netwiz
                    commit netwiz
EOF

                # 4. 重启
                # 先立即返回成功给前端，防止 XHR 超时报错
                echo '{"result":0}'
                
                # 4. 放入后台环境执行重启和唤醒
                (
                    sleep 1
                    /etc/init.d/dnsmasq restart
                    /etc/init.d/firewall reload
                    
                    # 唤醒高级应用
                    sleep 2
                    wakeup_apps
                ) >/dev/null 2>&1 &
                
                exit 0
                ;;

            export_config)

                FILE_LIST=""
                for f in network wireless dhcp firewall netwiz; do
                    if [ -s "/etc/config/$f" ]; then
                        FILE_LIST="$FILE_LIST etc/config/$f"
                    fi
                done

                if [ -n "$FILE_LIST" ]; then
                    timestamp=$(date +%Y%m%d_%H%M%S | tr -d '\r\n')
                    dl_name="NetWiz_NetConf_${timestamp}.tar.gz"
                    
                    backup_file="/www/luci-static/${dl_name}"

                    rm -f /www/luci-static/NetWiz_NetConf_*.tar.gz 2>/dev/null

                    # 打包文件
                    tar -czf "$backup_file" -C / $FILE_LIST 2>/dev/null

                    if [ -s "$backup_file" ]; then
                        chmod 644 "$backup_file" 2>/dev/null
                        printf '{"url":"/luci-static/%s", "filename":"%s"}\n' "$dl_name" "$dl_name"
                        
                        # 120 秒后删除
                        ( sleep 120; rm -f "$backup_file" ) >/dev/null 2>&1 &
                    else
                        printf '{"error":"Archive creation failed"}\n'
                    fi
                else
                    printf '{"error":"No files to backup"}\n'
                fi
                exit 0
                ;;

            wake_device)
                input=$(cat)
                mac=$(echo "$input" | jsonfilter -e '@.mac' | tr 'A-Z' 'a-z')
                [ -n "$mac" ] && {
                    # 使用 OpenWrt 內建的唤醒
                    if command -v etherwake >/dev/null 2>&1; then
                        etherwake -b -i br-lan "$mac" >/dev/null 2>&1
                    elif command -v ether-wake >/dev/null 2>&1; then
                        ether-wake -b -i br-lan "$mac" >/dev/null 2>&1
                    fi
                }
                echo '{"result":0}'
                exit 0
                ;;    

            list_backups)
                mkdir -p /root/netwiz_bak
                # 按时间倒序获取压缩包名
                files=$(ls -t /root/netwiz_bak/*.tar.gz 2>/dev/null | awk -F/ '{print $NF}')
                
                printf '{"backups":['
                first=1
                for f in $files; do
                    if [ "$first" -eq 1 ]; then first=0; else printf ','; fi
                    printf '"%s"' "$f"
                done
                printf ']}\n'
                exit 0
                ;;

            import_config)
                input=$(cat)
                b64data=$(echo "$input" | jsonfilter -e '@.data')
                file_name=$(echo "$input" | jsonfilter -e '@.file')
                
                restore_file="/tmp/netwiz_restore.tar.gz"
                has_file=0
                
                # data 是电脑上传，file_name 是选择路由器本地备份
                if [ -n "$b64data" ]; then
                    echo "$b64data" | base64 -d > "$restore_file"
                    has_file=1
                elif [ -n "$file_name" ] && [ -f "/root/netwiz_bak/$file_name" ]; then
                    cp "/root/netwiz_bak/$file_name" "$restore_file"
                    has_file=1
                fi
                
                if [ "$has_file" -eq 1 ]; then
                    mkdir -p /root/netwiz_bak
                    
                    backup_file="/root/netwiz_bak/netwiz_pre_import_$(date +%Y%m%d_%H%M%S).tar.gz"
                    
                    FILE_LIST=""
                    for f in network wireless dhcp firewall netwiz; do
                        if [ -s "/etc/config/$f" ]; then FILE_LIST="$FILE_LIST etc/config/$f"; fi
                    done
                    tar -czf "$backup_file" -C / $FILE_LIST 2>/dev/null

                    # --- 开始安全沙盒防呆/防黑客逻辑 ---
                    mkdir -p /tmp/nw_import_tmp
                    tar -xzf "$restore_file" -C /tmp/nw_import_tmp/ >/dev/null 2>&1

                    # 1. 检查解压是否报错
                    if [ $? -ne 0 ]; then
                        rm -rf /tmp/nw_import_tmp "$restore_file"
                        echo '{"error":"Invalid archive format"}'
                        exit 0
                    fi

                    # 2. 特征码强校验
                    if [ ! -f "/tmp/nw_import_tmp/etc/config/network" ] && [ ! -f "/tmp/nw_import_tmp/etc/config/dhcp" ] && [ ! -f "/tmp/nw_import_tmp/etc/config/netwiz" ]; then
                        rm -rf /tmp/nw_import_tmp "$restore_file"
                        echo '{"error":"Missing signature files"}'
                        exit 0
                    fi

                    # 3. 白名单安全覆盖
                    for f in network wireless dhcp firewall netwiz; do
                        if [ -f "/tmp/nw_import_tmp/etc/config/$f" ]; then
                            cp -f "/tmp/nw_import_tmp/etc/config/$f" "/etc/config/$f"
                        fi
                    done

                    # 清理沙盒与残留
                    rm -rf /tmp/nw_import_tmp "$restore_file"
                    # --- 🛡️ 安全逻辑结束 ---
                    
                    echo '{"result":0}'
                    
                    # 延时 2 秒后重启网络相关服务生效配置
                    (
                        sleep 2
                        /etc/init.d/network restart
                        /etc/init.d/dnsmasq restart
                        /etc/init.d/odhcpd restart
                        /etc/init.d/firewall restart
                        
                        sleep 3
                        wakeup_apps
                    ) >/dev/null 2>&1 &
                else
                    echo '{"error":"No valid backup data or file provided"}'
                fi
                exit 0
                ;;

            auto_backup)
                # 备份目录
                mkdir -p /root/netwiz_bak
                
                # 1. 计算 MD5 特征码
                current_md5=$(cat /etc/config/network /etc/config/wireless /etc/config/dhcp /etc/config/firewall /etc/config/netwiz 2>/dev/null | md5sum | awk '{print $1}')
                # 将 MD5 记录文件也移入专属目录
                last_md5=$(cat /root/netwiz_bak/.netwiz_last_md5 2>/dev/null)
                
                # 2. MD5 发生变化备份
                if [ "$current_md5" != "$last_md5" ]; then
                    timestamp=$(date +%Y%m%d_%H%M%S)
                    backup_file="/root/netwiz_bak/netwiz_auto_${timestamp}.tar.gz"
                    
                    FILE_LIST=""
                    for f in network wireless dhcp firewall netwiz; do
                        if [ -s "/etc/config/$f" ]; then FILE_LIST="$FILE_LIST etc/config/$f"; fi
                    done
                    tar -czf "$backup_file" -C / $FILE_LIST 2>/dev/null
                    
                    # 记录最新的 MD5
                    echo "$current_md5" > /root/netwiz_bak/.netwiz_last_md5
                    logger -t Netwiz "✅ Auto-backup created: $backup_file"
                    
                    # 3. 保留最近的 7 份自动备份
                    ls -t /root/netwiz_bak/netwiz_auto_*.tar.gz 2>/dev/null | tail -n +8 | xargs rm -f 2>/dev/null
                    # 保留5 份高危操作前备份
                    ls -t /root/netwiz_bak/netwiz_pre_*.tar.gz 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null
                else
                    logger -t Netwiz "💤 Auto-backup skipped: Config unchanged"
                fi
                
                echo '{"result":0}'
                exit 0
                ;;

            analyze_conns)
                input=$(cat)
                ip=$(echo "$input" | jsonfilter -e '@.ip')
                
                if ! echo "$ip" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}$'; then
                    echo '{"error":"INVALID_IP"}'
                    exit 1
                fi
                
                raw_file="/tmp/nw_conns_${ip}.txt"
                
                if [ -f /proc/net/nf_conntrack ]; then
                    awk -v ip="$ip" '{for(i=1;i<=NF;i++)if($i~/^src=/){split($i,a,"="); if(a[2]==ip) print $0; break}}' /proc/net/nf_conntrack 2>/dev/null > "$raw_file"
                elif command -v conntrack >/dev/null 2>&1; then
                    conntrack -L 2>/dev/null | awk -v ip="$ip" '{for(i=1;i<=NF;i++)if($i~/^src=/){split($i,a,"="); if(a[2]==ip) print $0; break}}' > "$raw_file"
                fi
                
                # 分类统計
                stats=$(awk '
                BEGIN { web=0; dns=0; udp_media=0; p2p=0; other=0; total=0 }
                {
                    total++;
                    proto = $3;
                    dport = 0;
                    for(i=1;i<=NF;i++) {
                        if($i ~ /^dport=/) { split($i,a,"="); dport=a[2]+0; break; }
                    }
                    
                    if (dport == 80 || dport == 443) { web++; }
                    else if (dport == 53 || dport == 5353 || dport == 123) { dns++; }
                    else if (proto == "udp") { udp_media++; }
                    else if (dport > 10000) { p2p++; }
                    else { other++; }
                }
                END {
                    printf "{\"total\":%d, \"web\":%d, \"dns\":%d, \"udp_media\":%d, \"p2p\":%d, \"other\":%d}", total, web, dns, udp_media, p2p, other
                }' "$raw_file")
                
                # 截取前 50 条原始数据給前端黑框
                raw_logs=$(head -n 50 "$raw_file" | sed 's/"/\\"/g' | awk '{printf "\"%s\",", $0}' | sed 's/,$//')
                
                rm -f "$raw_file"
                echo "{\"stats\": $stats, \"raw\": [$raw_logs]}"
                exit 0
                ;;
        esac
        ;;
esac
exit 1
