#: applications/luci-app-acl/root/usr/share/luci/menu.d/luci-app-acl.json:3
msgid "ACL Settings"
msgstr "Ustawienia ACL"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:112
msgid "ACL group"
msgstr "Grupa ACL"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:114
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:333
msgid "Access level"
msgstr "Poziom dostępu"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:302
msgid "Cannot encrypt plaintext password since uhttpd is not installed."
msgstr ""
"Nie można zaszyfrować zwykłego hasła tekstowego, ponieważ uhttpd nie jest "
"zainstalowany."

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:113
msgid "Description"
msgstr "Opis"

#: applications/luci-app-acl/root/usr/share/rpcd/acl.d/luci-app-acl.json:3
msgid "Grant access to ACL configuration"
msgstr "Udziel dostępu do konfiguracji ACL"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:249
msgid "Login name"
msgstr "Nazwa użytkownika"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:239
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:246
msgid "LuCI Logins"
msgstr "Loginy LuCI"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:246
msgid "New account"
msgstr "Nowe konto"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:280
msgid "Password value"
msgstr "Wartość hasła"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:254
msgid "Password variant"
msgstr "Wariant hasła"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:35
msgid "Policy: contain digits"
msgstr "Zasady: zawieraj cyfry"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:41
msgid "Policy: contain special characters"
msgstr "Zasady: zawieraj znaki specjalne"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:38
msgid "Policy: contain uppercase/lowercase"
msgstr "Zasady: zawieraj wielkie/małe litery"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:32
msgid "Policy: min. length of %s characters"
msgstr "Zasady: min. długość %s znaków"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:327
msgid "Read access"
msgstr "Dostęp do odczytu"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:319
msgid "Session timeout"
msgstr "Limit czasu sesji"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:120
msgctxt "Set all permissions in the table below to one of the given values"
msgid "Set all:"
msgstr "Ustaw wszystko:"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:213
msgid ""
"The LuCI ACL management is in an experimental stage! It does not yet work "
"reliably with all applications"
msgstr ""
"Zarządzanie LuCI ACL jest na etapie eksperymentalnym! Nie działa jeszcze "
"niezawodnie we wszystkich aplikacjach"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:294
msgid "The password may not start with \"$p$\"."
msgstr "Hasło nie może zaczynać się od \"$p$\"."

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:268
msgid "The system account to use the password from"
msgstr "Konto systemowe do używania hasła z"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:268
msgid "UNIX account"
msgstr "Konto UNIX"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:256
msgid "Use UNIX password in /etc/shadow"
msgstr "Użyj hasła UNIX w /etc/shadow"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:257
msgid "Use encrypted password hash"
msgstr "Użyj zaszyfrowanej wartości skrótu hasła"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:330
msgid "Write access"
msgstr "Dostęp do zapisu"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:101
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:123
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:144
msgctxt "No permissions granted"
msgid "denied"
msgstr "Odmowa dostępu"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:324
msgid "does not expire"
msgstr "Nie wygasa"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:97
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:129
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:146
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:335
msgctxt "All permissions granted"
msgid "full"
msgstr "Pełne"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:337
msgctxt "Select individual permissions manually"
msgid "individual"
msgstr "Indywidualne"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:99
msgctxt "Some permissions granted"
msgid "partial (%d/%d)"
msgstr "Częściowe (%d/%d)"

#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:126
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:145
#: applications/luci-app-acl/htdocs/luci-static/resources/view/system/acl.js:336
msgctxt "Only read permissions granted"
msgid "readonly"
msgstr "Tylko do odczytu"

