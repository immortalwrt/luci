const category_maps = {
	encryption: encryption_map,
	aead: aead_map,
	integrity: integrity_map,
	prf: prf_map,
	ke: ke_map
};

const methods = {
	'list-algs': {
		args: { type: 'type' },
		call: function(req) {
			const result = {
				error: null,
				data: null
			};
			const cmd = '/usr/sbin/swanmon get-algorithms';
			const categories = keys(category_maps);
			let output;
			let selected_categories = categories;
			if (req && req.args && req.args.type)
				selected_categories = [req.args.type];

			try {
				output = json(popen(cmd)?.read?.('all'));
			}
			catch (e) {
				result.error = e.message;
				return result;
			}

			if (length(output.errors) > 0)
				result.error = output.errors[0].message;

			if (output.data) {
				result.data = {};

				for (let category in selected_categories) {
					const category_map = category_maps[category];
					const output_algorithms = output.data[category];

					result.data[category] = [];

					for (let algorithm_name, algorithm_plugin in output_algorithms) {
						const map_algorithm = category_map[algorithm_name] ?? [];
						if (!map_algorithm)
							continue;

						for (let algorithm in map_algorithm) {
							push(result.data[category], {
								name: algorithm.name,
								plugin: algorithm_plugin,
								insecure: algorithm.insecure
							});
						}
					}
				}
			}

			return result;
		}
	}
};

return { 'luci.swanctl': methods };
