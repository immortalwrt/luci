msgstr "Zapnout editor souboru akcí"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:374
msgid "Enable compression"
msgstr "Zapnout kompresi"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:227
msgid "Enable on-the-fly certificate generation for HTTPS connections."
msgstr "Zapnout průběžné generování certifikátů pro HTTP spojení."

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:197
msgid "Enable proxy authentication forwarding"
msgstr "Povolit předávání autentizace proxy"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:172
msgid "Enable remote toggle"
msgstr "Zapnout vzdálené vyp/zap"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:177
msgid "Enable remote toggle via HTTP"
msgstr "Zapnout vzdálené vyp/zap přes HTTP"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:36
msgid "Enable/Disable autostart of Privoxy"
msgstr "Zap/vypnout automatické spouštění Privoxy"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:166
msgid "Enable/Disable filtering when Privoxy starts."
msgstr "Povolit / zakázat filtrování při spuštění privoxy."

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:36
msgid "Enabled"
msgstr "Povoleno"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:199
msgid ""
"Enabling this option is NOT recommended if there is no parent proxy that "
"requires authentication!"
msgstr ""
"Povolení této možnosti NENÍ doporučeno, pokud neexistuje nadřazený proxy "
"server vyžadující ověření!"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:188
msgid "Enforce page blocking"
msgstr "Vynucovat blokování stránek"

#: applications/luci-app-privoxy/htdocs/luci-static/resources/view/privoxy/privoxy.js:290
